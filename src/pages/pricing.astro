---
import Layout from '~/layouts/Layout.astro';
import PageHero from '~/components/PageHero.astro';
import Faq from '~/components/Faq.astro';
import FinalCTA from '~/components/home/FinalCTA.astro';
import Icon from '~/components/ui/Icon.astro';
import { SITE } from '~/lib/site';

const { single, agency } = SITE.pricing;

const tiers = [
  {
    id: 'single',
    name: single.name,
    priceMonthly: single.price,
    priceYearly: single.price,
    desc: 'Solo operators and boutique firms running one portal.',
    cta: 'Buy Single Site License',
    href: '#',
    feats: [
      '1 production install',
      'Unlimited clients & users',
      'All 8 modules',
      'White-label branding',
      '1 year of updates included',
      'Email support',
      'DigitalOcean / Docker deployment',
    ],
    excludes: [
      'Source code access',
      'Multi-install',
    ],
  },
  {
    id: 'agency',
    name: agency.name,
    priceMonthly: agency.price,
    priceYearly: agency.price,
    desc: 'Agencies running portals for themselves and their own clients.',
    cta: 'Buy Agency License',
    href: '#',
    popular: true,
    dark: true,
    feats: [
      'Up to 10 production installs',
      'Unlimited clients & users on each',
      'Full source-code access',
      'White-label rights (resell to your clients)',
      'Lifetime updates included',
      'Priority email + chat support',
      '4 hours of white-glove migration',
      'Managed hosting option',
    ],
    excludes: [],
  },
];

const billingFaqs = [
  { q: 'Is this really one-time?',
    a: 'Yes. The license fee is paid once. Year one of updates is included. After that, annual updates are optional ($97/yr Single Site, $297/yr Agency). Skip a year, your install keeps working — you only lose access to the next year of releases.' },
  { q: 'What payment methods do you accept?',
    a: 'Card (via Stripe), ACH (US/CA), and wire transfer for orders over $5,000. Invoice & PO accepted for organizations.' },
  { q: 'Do you offer refunds?',
    a: '30-day money-back guarantee, no questions asked. Email us within 30 days of purchase.' },
  { q: 'Can I upgrade from Single Site to Agency?',
    a: 'Yes — pay the difference, keep your install, gain source access and the additional install seats.' },
  { q: 'Are there discounts for non-profits / education?',
    a: 'Yes — 30% off for registered non-profits and accredited educational institutions. Email us with your details.' },
  { q: 'What about hosting?',
    a: 'Self-host on any VPS that runs Docker (DigitalOcean, Hetzner, AWS, anything). Or pick our managed hosting at $49/mo per install — same software, we run the server.' },
];

const compare = [
  { feat: 'Production installs', single: '1', agency: 'Up to 10' },
  { feat: 'Clients & users', single: 'Unlimited', agency: 'Unlimited' },
  { feat: 'All 8 modules', single: '✓', agency: '✓' },
  { feat: 'White-label branding', single: '✓', agency: '✓' },
  { feat: 'Source-code access', single: '—', agency: '✓' },
  { feat: 'Resell rights', single: '—', agency: '✓' },
  { feat: 'Year-one updates', single: '✓', agency: '✓' },
  { feat: 'Lifetime updates', single: '$97/yr after year 1', agency: 'Included' },
  { feat: 'Support', single: 'Email', agency: 'Priority email + chat' },
  { feat: 'White-glove migration', single: '—', agency: '4 hours' },
];
---
<Layout
  title="Pricing — Pay once. Own forever."
  description="One-time license. No per-seat tax. No monthly fees. Two tiers — $497 or $997. Includes white-label branding, year-one updates, and a 30-day money-back guarantee."
>
  <PageHero
    eyebrow="PRICING"
    title="Pay once. <em class='acc'>Own forever.</em>"
    subtitle="No monthly fees. No per-seat charges. No surprise quotas. One license. Yours."
  >
    <div class="billing-toggle reveal" data-billing="monthly" id="billing-toggle" style="margin-top:32px;">
      <button data-period="monthly" aria-pressed="true">Monthly updates</button>
      <button data-period="yearly" aria-pressed="false">Save 17% yearly</button>
    </div>
    <p class="reveal" style="margin-top:14px;font-size:13px;color:var(--color-ink-3);">
      Toggle is informational — license is one-time either way. Toggle adjusts the optional <strong>updates plan</strong>.
    </p>
  </PageHero>

  <section class="sect" style="padding-top:0;">
    <div class="container-wide">
      <div class="tiers" id="tier-grid" data-billing="monthly">
        {tiers.map(t => (
          <div class={`tier reveal ${t.dark ? 'tier-dark' : ''}`} id={t.id}>
            {t.popular && <span class="popular">MOST POPULAR</span>}
            <div class="tier-name">{t.name}</div>
            <div class="tier-price">
              <span class="cc-serif num">${t.priceMonthly}</span>
              <span class="cycle">one-time license</span>
            </div>
            <p class="tier-desc">{t.desc}</p>
            <div class="updates-line">
              <span class="muted">Updates plan (optional):</span>
              <strong class="num">
                <span class="price-monthly">${t.id === 'single' ? '12' : '29'}/mo</span>
                <span class="price-yearly">${t.id === 'single' ? '97' : '297'}/yr</span>
              </strong>
            </div>
            <a href={t.href} class={t.dark ? 'btn btn-primary btn-lg' : 'btn btn-dark btn-lg'} style="width:100%;margin-bottom:22px;">
              {t.cta} <Icon name="arrow" class="arrow" />
            </a>
            <ul>
              {t.feats.map(f => (
                <li><span class="check"><Icon name="check" /></span>{f}</li>
              ))}
              {t.excludes.map(f => (
                <li class="excl"><span class="x"><Icon name="x" /></span>{f}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <p class="guarantee">
        Every license includes a <strong>30-day money-back guarantee</strong>.
      </p>
    </div>
  </section>

  <section class="sect" style="background:var(--color-bg-2);">
    <div class="container-wide">
      <div class="reveal" style="text-align:center;max-width:680px;margin:0 auto 48px;">
        <h2 class="cc-h2">Tier comparison</h2>
      </div>
      <div class="reveal compare-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th></th>
              <th>Single Site</th>
              <th>Agency License</th>
            </tr>
          </thead>
          <tbody>
            {compare.map(row => (
              <tr>
                <td>{row.feat}</td>
                <td>{row.single}</td>
                <td class="cc">{row.agency}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <Faq items={billingFaqs} eyebrow="PRICING FAQ" heading="Billing, plainly." />
  <FinalCTA />
</Layout>

<script>
  const toggle = document.getElementById('billing-toggle');
  const grid = document.getElementById('tier-grid');
  if (toggle && grid) {
    toggle.querySelectorAll<HTMLButtonElement>('button').forEach(btn => {
      btn.addEventListener('click', () => {
        const p = btn.getAttribute('data-period') || 'monthly';
        toggle.setAttribute('data-billing', p);
        grid.setAttribute('data-billing', p);
        toggle.querySelectorAll<HTMLButtonElement>('button').forEach(b => {
          b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
        });
      });
    });
  }
</script>

<style>
  .billing-toggle {
    display: inline-flex; padding: 4px;
    background: #fff; border: 1px solid var(--color-line);
    border-radius: 999px;
  }
  .billing-toggle button {
    background: transparent; border: 0;
    padding: 8px 18px; border-radius: 999px;
    font-size: 13.5px; font-weight: 600; color: var(--color-ink-2);
    cursor: pointer;
    transition: background .2s ease, color .2s ease;
    font-family: inherit;
  }
  .billing-toggle button[aria-pressed="true"] {
    background: var(--color-navy-900); color: #fff;
  }

  .tiers {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 16px; max-width: 920px; margin: 0 auto;
  }
  .tier {
    position: relative;
    background: #fff; color: var(--color-ink);
    border: 1px solid var(--color-line);
    border-radius: 14px; padding: 32px;
    box-shadow: var(--shadow-sm);
  }
  .tier-dark {
    background: var(--color-navy-900); color: #fff;
    border-color: var(--color-navy-700);
    box-shadow: 0 30px 60px -20px rgba(10,31,46,.4);
  }
  .popular {
    position: absolute; top: 16px; right: 16px;
    font-size: 9.5px; font-weight: 700; padding: 4px 9px; border-radius: 4px;
    background: var(--color-orange); color: #fff; letter-spacing: 0.08em;
  }
  .tier-name {
    font-size: 11px; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--color-ink-3); margin-bottom: 14px;
  }
  .tier-dark .tier-name { color: rgba(255,255,255,.55); }
  .tier-price { display: flex; align-items: baseline; gap: 8px; margin-bottom: 8px; }
  .tier-price .cc-serif { font-size: 56px; font-weight: 700; line-height: 1; color: var(--color-ink); }
  .tier-dark .tier-price .cc-serif { color: #fff; }
  .cycle { font-size: 13px; color: var(--color-ink-3); white-space: nowrap; }
  .tier-dark .cycle { color: rgba(255,255,255,.5); }
  .tier-desc { font-size: 14px; color: var(--color-ink-2); line-height: 1.5; margin-bottom: 18px; }
  .tier-dark .tier-desc { color: rgba(255,255,255,.7); }
  .updates-line {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 12px 14px; background: var(--color-bg-2); border-radius: 8px;
    margin-bottom: 18px; font-size: 13px;
  }
  .tier-dark .updates-line { background: rgba(255,255,255,.06); color: rgba(255,255,255,.85); }
  .updates-line .muted { color: var(--color-ink-3); }
  .tier-dark .updates-line .muted { color: rgba(255,255,255,.6); }
  .updates-line strong { color: var(--color-ink); }
  .tier-dark .updates-line strong { color: #fff; }
  .tier ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 9px; }
  .tier li { display: flex; gap: 8px; font-size: 13.5px; color: var(--color-ink-2); }
  .tier-dark li { color: rgba(255,255,255,.85); }
  .tier li.excl { color: var(--color-ink-4); }
  .tier-dark li.excl { color: rgba(255,255,255,.45); }
  .tier-dark .check { background: rgba(43,179,179,.2); color: var(--color-teal); }

  .guarantee { text-align: center; margin: 32px 0 0; font-size: 13px; color: var(--color-ink-3); }
  .guarantee strong { color: var(--color-ink); }

  .compare-wrap {
    overflow-x: auto; border-radius: 14px;
    border: 1px solid var(--color-line); background: #fff;
  }
  .compare-table { width: 100%; border-collapse: collapse; font-size: 14.5px; min-width: 600px; }
  .compare-table th, .compare-table td {
    text-align: left; padding: 14px 22px;
    border-bottom: 1px solid var(--color-line-2);
  }
  .compare-table th {
    font-size: 11px; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--color-ink-3);
    background: var(--color-bg-2); border-bottom-color: var(--color-line);
  }
  .compare-table tr:last-child td { border-bottom: none; }
  .compare-table td.cc { color: var(--color-orange); font-weight: 600; }

  @media (max-width: 720px) { .tiers { grid-template-columns: 1fr; } }
</style>
