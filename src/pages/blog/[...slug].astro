---
import Layout from '~/layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import Icon from '~/components/ui/Icon.astro';
import { SITE } from '~/lib/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: { '@type': 'Person', name: post.data.author },
  publisher: { '@type': 'Organization', name: SITE.name, logo: { '@type': 'ImageObject', url: `${SITE.url}/clientcove-logo.svg` } },
  mainEntityOfPage: `${SITE.url}/blog/${post.id}`,
};
---
<Layout
  title={post.data.title}
  description={post.data.description}
  jsonLd={articleLd}
>
  <article class="post">
    <header class="post-head">
      <div class="container" style="max-width:760px;">
        <a href="/blog" class="back-link">
          <Icon name="arrow" class="back-arrow" /> All posts
        </a>
        <span class="cat">{post.data.category}</span>
        <h1 class="cc-h1" style="margin:18px 0 22px;">{post.data.title}</h1>
        <p class="lede">{post.data.description}</p>
        <div class="post-meta">
          <span>{post.data.author}</span>
          <span>·</span>
          <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
          {post.data.tags.length > 0 && (
            <>
              <span>·</span>
              <span class="tags">
                {post.data.tags.map(t => <span class="tag">#{t}</span>)}
              </span>
            </>
          )}
        </div>
      </div>
    </header>

    <div class="container" style="max-width:760px;">
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>

  <section class="sect" style="background:var(--color-bg-2);">
    <div class="container" style="max-width:680px;text-align:center;">
      <h2 class="cc-h2">Run your client work like Sara does.</h2>
      <p style="font-size:17px;color:var(--color-ink-2);margin:18px 0 32px;">
        ClientCove is a self-hosted, white-label client portal. Pay once. Own forever.
      </p>
      <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">
        <a href="/pricing" class="btn btn-primary btn-lg">Buy ClientCove — $497 <Icon name="arrow" class="arrow" /></a>
        <a href="/" class="btn btn-ghost btn-lg">See features</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .post-head { padding: 80px 0 40px; }
  .back-link {
    display: inline-flex; align-items: center; gap: 6px;
    color: var(--color-ink-3); font-size: 13.5px; font-weight: 500;
    margin-bottom: 24px;
  }
  .back-link .back-arrow { transform: rotate(180deg); }
  .cat {
    font-size: 11px; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--color-orange);
  }
  .lede {
    font-family: var(--font-serif);
    font-size: 22px; line-height: 1.45;
    color: var(--color-ink-2); margin: 0 0 22px;
    font-weight: 400; text-wrap: pretty;
  }
  .post-meta {
    display: flex; flex-wrap: wrap; gap: 8px;
    font-size: 13px; color: var(--color-ink-3);
    align-items: center; padding-bottom: 30px;
    border-bottom: 1px solid var(--color-line);
  }
  .tags { display: inline-flex; gap: 6px; flex-wrap: wrap; }
  .tag {
    font-size: 12px; padding: 2px 8px; border-radius: 999px;
    background: var(--color-bg-2); color: var(--color-ink-2);
  }

  .prose { padding: 36px 0 100px; font-size: 17.5px; line-height: 1.7; color: var(--color-ink-2); }
  .prose :global(h2) {
    font-family: var(--font-serif);
    font-size: 30px; line-height: 1.2; letter-spacing: -0.02em;
    color: var(--color-ink); font-weight: 600;
    margin: 56px 0 16px;
  }
  .prose :global(h3) {
    font-family: var(--font-serif);
    font-size: 22px; line-height: 1.3; letter-spacing: -0.015em;
    color: var(--color-ink); font-weight: 600;
    margin: 40px 0 12px;
  }
  .prose :global(p) { margin: 0 0 18px; }
  .prose :global(p) :global(strong) { color: var(--color-ink); }
  .prose :global(a) { color: var(--color-orange); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 2px; }
  .prose :global(a:hover) { color: var(--color-orange-600); }
  .prose :global(ul), .prose :global(ol) { padding-left: 22px; margin: 0 0 18px; }
  .prose :global(li) { margin-bottom: 8px; }
  .prose :global(blockquote) {
    margin: 28px 0; padding: 4px 0 4px 22px;
    border-left: 3px solid var(--color-orange);
    font-family: var(--font-serif); font-style: italic;
    font-size: 22px; color: var(--color-ink); line-height: 1.4;
  }
  .prose :global(blockquote) :global(p) { margin: 0; }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--color-bg-2);
    padding: 2px 6px; border-radius: 4px;
    color: var(--color-orange-600);
  }
  .prose :global(pre) {
    background: var(--color-navy-900); color: #DEE7EE;
    border-radius: 12px; padding: 20px 24px; overflow-x: auto;
    margin: 24px 0; font-size: 13.5px; line-height: 1.65;
  }
  .prose :global(pre) :global(code) {
    background: transparent; padding: 0; color: inherit; font-size: inherit;
  }
  .prose :global(table) {
    width: 100%; border-collapse: collapse; margin: 24px 0;
    font-size: 14.5px;
  }
  .prose :global(th), .prose :global(td) {
    text-align: left; padding: 12px 14px;
    border-bottom: 1px solid var(--color-line-2);
  }
  .prose :global(th) {
    font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--color-ink-3);
    border-bottom-color: var(--color-line);
  }
  .prose :global(hr) {
    border: 0; border-top: 1px solid var(--color-line); margin: 40px 0;
  }
</style>
