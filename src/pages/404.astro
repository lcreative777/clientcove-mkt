---
import Layout from '~/layouts/Layout.astro';
import Mark from '~/components/ui/Mark.astro';
import Icon from '~/components/ui/Icon.astro';
---
<Layout title="404 — Lost in the cove" description="The page you were looking for isn't here." noindex>
  <section class="four-oh-four">
    <svg class="mesh" viewBox="0 0 1600 600" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <radialGradient id="m1" cx="30%" cy="30%" r="55%"><stop offset="0%" stop-color="#E76F2A" stop-opacity=".22"/><stop offset="100%" stop-color="#E76F2A" stop-opacity="0"/></radialGradient>
        <radialGradient id="m2" cx="70%" cy="70%" r="55%"><stop offset="0%" stop-color="#2BB3B3" stop-opacity=".22"/><stop offset="100%" stop-color="#2BB3B3" stop-opacity="0"/></radialGradient>
      </defs>
      <rect width="1600" height="600" fill="url(#m1)"/>
      <rect width="1600" height="600" fill="url(#m2)"/>
    </svg>
    <div class="container" style="position:relative;z-index:1;">
      <Mark size={64} />
      <p class="num eyebrow" style="margin-top:24px;justify-content:center;">404 · Off the map</p>
      <h1 class="cc-display" style="font-size:clamp(60px,9vw,120px);">Lost in the cove.</h1>
      <p class="sub">The page you were looking for isn't here. Try one of these instead:</p>
      <div class="links">
        <a href="/" class="btn btn-primary">Home <Icon name="arrow" class="arrow" /></a>
        <a href="/features" class="btn btn-ghost">Features</a>
        <a href="/pricing" class="btn btn-ghost">Pricing</a>
        <a href="/blog" class="btn btn-ghost">Blog</a>
        <a href="/contact" class="btn btn-ghost">Contact</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .four-oh-four {
    position: relative; padding: 120px 0 160px;
    text-align: center; overflow: hidden; min-height: 60vh;
    display: flex; align-items: center; justify-content: center;
  }
  .four-oh-four .mesh {
    position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0;
  }
  .four-oh-four .sub {
    font-size: 18px; color: var(--color-ink-2);
    max-width: 480px; margin: 18px auto 0;
  }
  .four-oh-four .links {
    margin-top: 32px;
    display: flex; gap: 10px; justify-content: center; flex-wrap: wrap;
  }
</style>
