---
import Layout from '~/layouts/Layout.astro';
import Mark from '~/components/ui/Mark.astro';
import Icon from '~/components/ui/Icon.astro';
import CurrentGlyph from '~/components/current/CurrentGlyph.astro';
import TierIcon from '~/components/current/TierIcon.astro';
import TierVisual from '~/components/current/TierVisual.astro';

const TIERS = [
  {
    id: 'comms',
    name: 'Comms',
    upstream: 'SendGrid',
    headline: 'Transactional email. Inbound parsing.',
    headlineItalic: 'Without becoming a deliverability engineer.',
    short: 'Email that actually delivers.',
    icon: 'mail' as const,
    accent: '#2BB3B3',
    price: '$29.99',
    period: '/mo',
    quota: '50,000 sends · inbound parsing',
    proof: ['SPF · DKIM · DMARC pre-wired', 'Bounce + complaint handling', 'Inbound webhook routing', 'Warm-up included'],
    replaces: '"I\'ll just use Gmail SMTP." (works for 100, breaks at 1,000.)',
  },
  {
    id: 'react',
    name: 'React',
    upstream: 'Pusher',
    headline: 'Live tickets, live cursors, live notifications.',
    headlineItalic: 'Zero infrastructure on your end.',
    short: 'Real-time, without the WebSocket headaches.',
    icon: 'wave' as const,
    accent: '#E76F2A',
    price: '$59.99',
    period: '/mo',
    quota: '200 concurrent connections',
    proof: ['Reconnect & backoff handled', 'Presence + activity feed', 'Live ticket inbox', 'Document co-presence'],
    replaces: 'Long-polling (slow, expensive) or your own WebSocket cluster (do not).',
  },
  {
    id: 'surge',
    name: 'Surge',
    upstream: 'OpenRouter + Gemini',
    headline: 'AI for ticket polish, fuzzy search, and the help bot.',
    headlineItalic: 'Routed across providers, billed flat.',
    short: 'AI features. You don\'t manage the inference.',
    icon: 'spark' as const,
    accent: '#7E5BD7',
    price: '$99',
    period: '/mo',
    quota: '50,000 operations · provider failover',
    proof: ['Multi-provider failover', 'Model deprecation handled', 'Per-feature rate limits', 'Token + cost telemetry'],
    replaces: 'Juggling OpenRouter dashboards and writing fallback code when Gemini is down.',
  },
];

const FAQ_ITEMS = [
  { q: 'What if I want to use my own SendGrid, Pusher, or OpenAI?',
    a: 'Toggle Current off, paste your own credentials. Same UI, same features, same data. ClientCove takes nothing — you pay the upstream vendor directly.' },
  { q: 'What happens to my data if I cancel a Current tier?',
    a: 'Nothing. Your install keeps running. You\'ll just lose that one feature until you reconnect a provider — ours, or yours.' },
  { q: 'Can I start without Current and add it later?',
    a: 'Yes. Current is per-month, tied to your ClientCove license. Buy Cove today, run on your own infrastructure, switch any tier on next year if you want to stop maintaining it.' },
  { q: 'Is this SaaS or perpetual?',
    a: 'Cove is perpetual. You buy it once, you own it forever. Current is a managed services subscription on top, billed monthly. Use either or both. The license is never bait-and-switched.' },
  { q: 'How is Current Surge billed when traffic spikes?',
    a: 'Flat monthly with a generous quota. If you exceed it, we throttle gracefully (and notify you) rather than surprise-bill. You can upgrade tiers in-app.' },
  { q: 'Why three tiers and not one bundle?',
    a: 'Because most customers only need one or two. Pay for what you use — bundle all three only if you want to skip every integration project at once.' },
];
---
<Layout
  title="Current — Optional managed utilities for ClientCove"
  description="Cove is the platform. Current is the utilities — email, real-time, and AI inference. Pre-integrated providers under one toggle, with our credentials or yours."
>
  <!-- Hero -->
  <section class="cur-hero">
    <svg class="cur-hero-bg" viewBox="0 0 1440 600" preserveAspectRatio="none" aria-hidden="true">
      <defs>
        <linearGradient id="cwg" x1="0" x2="1">
          <stop offset="0" stop-color="#2BB3B3" stop-opacity="0"/>
          <stop offset=".5" stop-color="#2BB3B3" stop-opacity=".5"/>
          <stop offset="1" stop-color="#2BB3B3" stop-opacity="0"/>
        </linearGradient>
      </defs>
      {[100, 180, 260, 340, 420, 500].map((y, i) => (
        <path
          d={`M-100 ${y} C 360 ${y - 30 + i*4}, 720 ${y + 30 + i*2}, 1080 ${y - 20}, 1540 ${y + 10}`}
          stroke="url(#cwg)" stroke-width={1 + i * 0.2} fill="none"/>
      ))}
    </svg>

    <div class="container-wide" style="position:relative;text-align:center;">
      <div class="prod-switch">
        <a href="/" class="ps-link">Cove</a>
        <span class="ps-active">
          <CurrentGlyph size={14} />
          Current
        </span>
      </div>

      <div class="eyebrow teal" style="margin-top:32px;justify-content:center;">
        <span class="badge" style="background:rgba(43,179,179,.12);color:var(--color-teal-600);">Optional managed services</span>
        <span class="label">A sibling to Cove · not an upsell</span>
      </div>

      <h1 class="cc-display" style="margin-top:24px;max-width:1100px;margin-inline:auto;">
        Cove is the platform.<br/>
        <em class="cool">Current</em> is the utilities.
      </h1>

      <p class="cur-lede">
        Three utilities every service business needs — deliverability, real-time, and AI inference.
        Packaged into ClientCove so you buy them in one place instead of three.
      </p>
      <div class="cur-sub">
        One bill. Pre-integrated providers. Or paste your own keys, anytime.
      </div>

      <div class="tier-mini">
        {TIERS.map(t => (
          <a href={`#${t.id}`} class="card mini-card" style={`--accent:${t.accent};`}>
            <span class="mini-icon" style={`background:${t.accent}1A;`}>
              <TierIcon kind={t.icon} color={t.accent} />
            </span>
            <div class="mini-text">
              <div class="mini-name">
                Current <span style={`color:${t.accent};`}>{t.name}</span>
              </div>
              <div class="mini-up">{t.upstream}, pre-integrated</div>
            </div>
          </a>
        ))}
      </div>

      <div class="cur-cta-row">
        <a href="#pricing" class="btn btn-dark btn-lg">See pricing <Icon name="arrow" class="arrow"/></a>
        <a href="#proof" class="btn btn-ghost btn-lg">How the toggle works</a>
      </div>
    </div>
  </section>

  <!-- Promise band -->
  <section class="promise">
    <div class="container-wide promise-grid">
      <div class="promise-h">
        You <em class="acc">own</em> the platform. Buy your utilities through one convenient place — instead of stitching them together yourself.
      </div>
      <div class="promise-p">
        Cove is yours forever. Current is the utility bundle that runs alongside it — email, real-time, and AI inference, packaged so you buy them in one place instead of three.
        That's not a contradiction with <em>"Pay once. Own forever."</em> — it's the answer to the question
        that promise raises: <em>OK, but what about the parts that genuinely need a vendor?</em>
      </div>
    </div>
  </section>

  <!-- Toggle proof -->
  <section id="proof" class="toggle-proof">
    <div class="container-wide">
      <div style="text-align:center;max-width:760px;margin:0 auto;">
        <div class="eyebrow teal" style="justify-content:center;">
          <span class="label">The proof</span>
        </div>
        <h2 class="cc-h2" style="margin-top:14px;">
          One toggle. Same product.<br/>
          <em class="cool">Different payer.</em>
        </h2>
        <p class="proof-lede">
          Most "managed" tiers in tech are sticky on purpose. Ours isn't.
          Flip Current on — we manage it. Flip it off, paste your own keys — you manage it.
          Either way the rest of the portal works exactly the same.
        </p>
      </div>

      <div class="proof-frame">
        <div class="proof-bar">
          <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          <div class="proof-addr">portal.acmeagency.com / settings / current</div>
        </div>

        <div class="proof-body">
          <div class="proof-head">
            <div style="display:flex;align-items:center;gap:14px;">
              <span class="proof-tier-icon">
                <TierIcon kind="mail" color="#1F9999" />
              </span>
              <div>
                <div class="proof-tier-name">Current Comms</div>
                <div class="proof-tier-sub">Transactional email · inbound parsing</div>
              </div>
            </div>
            <div class="on-pill">
              <span class="pulse"></span>
              <span>ON</span>
            </div>
          </div>

          <div style="margin-top:22px;">
            <div class="proof-eyebrow">Provider</div>
            <div class="proof-options" data-proof-options>
              <button type="button" data-mode="managed" data-active="">
                <span class="radio"><span></span></span>
                <div>
                  <div class="opt-l">Use Current (managed)</div>
                  <div class="opt-d">We pay SendGrid. Flat monthly bill.</div>
                </div>
              </button>
              <button type="button" data-mode="byo">
                <span class="radio"><span></span></span>
                <div>
                  <div class="opt-l">Use my own SendGrid</div>
                  <div class="opt-d">Paste your API key. You pay the upstream bill.</div>
                </div>
              </button>
            </div>
          </div>

          <div class="proof-detail" data-mode="managed" data-active>
            <div class="detail-grid">
              <div>
                <div class="detail-l">Plan</div>
                <div class="detail-v cc-serif">Comms Standard</div>
                <div class="detail-s">$29.99 / mo · billed yearly</div>
              </div>
              <div>
                <div class="detail-l">Sends this month</div>
                <div class="detail-v num" style="font-family:var(--font-mono);font-size:16px;">4,217 / 50,000</div>
                <div class="bar"><div style="width:8.4%;background:var(--color-teal-600);"></div></div>
              </div>
              <div>
                <div class="detail-l">Status</div>
                <div style="margin-top:6px;display:inline-flex;align-items:center;gap:8px;">
                  <span class="pulse"></span>
                  <span style="font-size:13px;font-weight:600;color:var(--color-teal-600);">Delivering</span>
                </div>
                <a href="#" class="manage-link">Manage subscription →</a>
              </div>
            </div>
          </div>

          <div class="proof-detail" data-mode="byo">
            <div class="byo-grid">
              <div>
                <div class="detail-l">SendGrid API key</div>
                <div class="key-input">sk_••••••••••••••••3a7f</div>
              </div>
              <div>
                <div class="detail-l">Reply-to domain</div>
                <div class="key-input">replies.acmeagency.com</div>
              </div>
            </div>
            <div class="verified-row">
              <span class="check"><Icon name="check" /></span>
              <span style="font-size:13px;font-weight:600;color:var(--color-teal-600);">Verified · domain authenticated</span>
            </div>
            <div class="detail-s" style="margin-top:8px;">You pay SendGrid directly. ClientCove takes nothing.</div>
          </div>

          <div class="proof-foot">
            <span>Same product, every screen — only the payer changes.</span>
            <span class="convenience" data-convenience>Convenience tax: $29.99/mo</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Three tier deep-dives -->
  {TIERS.map((t, idx) => (
    <section id={t.id} class={`tier-section ${idx === 1 ? 'alt-bg' : ''}`}>
      <div class="container-wide tier-grid" data-reverse={idx % 2 === 1 ? '' : undefined}>
        <div class="tier-copy">
          <div class="eyebrow teal" style="flex-wrap:wrap;">
            <span class="badge" style={`background:${t.accent}1A;color:${t.accent};`}>
              <CurrentGlyph size={11} color={t.accent} />
              Current {t.name}
            </span>
            <span class="label">Tier {idx + 1} of 3</span>
          </div>
          <div class="tier-short">{t.short}</div>
          <h2 class="cc-h2" style="margin-top:12px;">
            {t.headline}<br/>
            <em class="cool">{t.headlineItalic}</em>
          </h2>

          <div class="tier-proof">
            {t.proof.map(p => (
              <div class="proof-row">
                <span class="check-wrap" style={`background:${t.accent}1A;color:${t.accent};`}>
                  <Icon name="check" />
                </span>
                {p}
              </div>
            ))}
          </div>

          <div class="replaces" style={`border-left-color:${t.accent};`}>
            <div class="replaces-l" style={`color:${t.accent};`}>Replaces</div>
            {t.replaces}
          </div>

          <div class="tier-price">
            <div class="price-num">
              <span class="p-amt cc-serif">{t.price}</span>
              <span class="p-period">{t.period}</span>
            </div>
            <div class="quota">{t.quota}</div>
            <div class="byo-pill">or BYO {t.upstream}, free</div>
          </div>

          <div class="tier-ctas">
            <a href="#pricing" class="btn btn-sm" style={`background:${t.accent};border-color:${t.accent};color:#fff;`}>
              Add Current {t.name} <Icon name="arrow" class="arrow" />
            </a>
            <a href="#" class="btn btn-ghost btn-sm">Setup guide (BYO)</a>
          </div>
        </div>
        <div class="tier-vis">
          <TierVisual kind={t.id as 'comms' | 'react' | 'surge'} />
        </div>
      </div>
    </section>
  ))}

  <!-- Pricing comparison table -->
  <section id="pricing" class="pricing-table-section on-dark">
    <div class="container-wide">
      <div style="text-align:center;max-width:720px;margin:0 auto;">
        <div class="eyebrow teal" style="justify-content:center;color:#2BB3B3;">
          <span class="label" style="color:#2BB3B3;">Pricing</span>
        </div>
        <h2 class="cc-h2" style="margin-top:14px;color:#fff;">
          Pay us for the convenience.<br/>
          <em class="cool">Or pay nothing</em> and bring your own keys.
        </h2>
        <p class="pt-lede">
          The convenience tax is the cost of skipping three vendor accounts and three integration projects.
          Worth it for most. Optional for everyone.
        </p>
      </div>

      <div class="pt-table">
        <div class="pt-head">
          <span>Tier</span>
          <span class="ar">Use Current (managed)</span>
          <span class="ar">Use your own</span>
        </div>

        {[
          { name: 'Comms', upstream: 'SendGrid', price: '$29.99/mo', quota: '50k sends', accent: '#2BB3B3', icon: 'mail' as const },
          { name: 'React', upstream: 'Pusher', price: '$59.99/mo', quota: '200 concurrent', accent: '#E76F2A', icon: 'wave' as const },
          { name: 'Surge', upstream: 'OpenRouter + Gemini', price: '$99/mo', quota: '50k operations', accent: '#7E5BD7', icon: 'spark' as const },
        ].map(r => (
          <div class="pt-row">
            <div style="display:flex;align-items:center;gap:14px;">
              <span class="pt-icon" style={`background:${r.accent}26;`}>
                <TierIcon kind={r.icon} color={r.accent} />
              </span>
              <div>
                <div class="pt-name cc-serif">Current {r.name}</div>
                <div class="pt-up">{r.upstream}</div>
              </div>
            </div>
            <div class="ar">
              <div class="pt-price cc-serif">{r.price}</div>
              <div class="pt-quota">{r.quota}</div>
            </div>
            <div class="ar">
              <div class="pt-free cc-serif">Free</div>
              <div class="pt-quota">+ your upstream bill</div>
            </div>
          </div>
        ))}

        <div class="pt-bundle">
          <div>
            <div class="pt-name cc-serif" style="font-size:22px;">Bundle all three</div>
            <div class="pt-up" style="font-size:12.5px;color:rgba(255,255,255,.6);">Comms + React + Surge · save ~21%</div>
          </div>
          <div class="ar">
            <div class="bundle-price cc-serif">$149<span style="font-size:14px;color:rgba(255,255,255,.6);">/mo</span></div>
            <div class="bundle-strike">$188.98/mo separately</div>
          </div>
          <div class="ar">
            <div class="pt-free cc-serif">Free</div>
            <div class="pt-quota">+ your three bills</div>
          </div>
        </div>
      </div>

      <p class="pt-foot">
        Your ClientCove license is permanent. Current is a separate, optional, month-to-month subscription.
        Cancel any tier without losing access to ClientCove — you'll just need to paste your own credentials to keep that feature on.
      </p>

      <div class="pt-ctas">
        <a href="/pricing" class="btn btn-primary btn-lg">Buy ClientCove + Current <Icon name="arrow" class="arrow" /></a>
        <a href="/pricing" class="btn btn-ghost-light btn-lg">Cove only — start here</a>
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="philosophy">
    <div class="container-wide phil-grid">
      <div>
        <div class="eyebrow ink"><span class="label">Why Current exists</span></div>
        <h2 class="cc-h2" style="margin-top:14px;">
          We pay these bills <em class="acc">ourselves.</em>
        </h2>
      </div>
      <div class="phil-content">
        <p>
          We built ClientCove for ourselves first. To run it, we pay SendGrid for email, Pusher for real-time, and OpenRouter for AI. Not because we had to — because those three problems are not worth solving from scratch.
        </p>
        <p>
          Customers asked us to package what we use. <em>Current is exactly that</em> — three pre-integrated providers, behind one toggle, with our credentials or yours.
        </p>
        <div class="phil-cards">
          {[
            ['You still own the platform.', 'Your perpetual license is untouched.'],
            ['Your data still lives in your install.', 'Current routes traffic — never holds your records.'],
            ['Cancel any tier, anytime.', 'Paste your own keys to keep the feature on.'],
            ['Pre-integrate, never lock in.', 'If we add a vendor, you can swap us out for them.'],
          ].map(p => (
            <div class="phil-card">
              <div class="phil-card-h">{p[0]}</div>
              <div class="phil-card-b">{p[1]}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="cur-faq">
    <div class="container-wide faq-grid">
      <div>
        <div class="eyebrow ink"><span class="label">FAQ</span></div>
        <h2 class="cc-h2" style="margin-top:14px;">
          The honest <em class="cool">trade-offs.</em>
        </h2>
        <p class="faq-lede">
          Current works because the answers don't change depending on who's reading.
        </p>
      </div>
      <div class="faq-list">
        {FAQ_ITEMS.map((it, i) => (
          <details class="faq-item" open={i === 0}>
            <summary>
              <span class="faq-q">{it.q}</span>
              <span class="faq-icon"><Icon name="plus" /></span>
            </summary>
            <div class="faq-body">
              <div><p>{it.a}</p></div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="on-dark cur-cta">
    <div class="grid-bg-dark" aria-hidden="true" style="position:absolute;inset:0;opacity:.5;"></div>
    <div class="cta-blob" aria-hidden="true"></div>
    <div class="container-wide" style="position:relative;text-align:center;">
      <div style="display:inline-flex;align-items:center;gap:16px;">
        <Mark size={48} />
        <span style="font-size:28px;color:rgba(255,255,255,.3);">+</span>
        <CurrentGlyph size={44} />
      </div>
      <h2 class="cc-h1" style="margin-top:28px;color:#fff;">
        Own the platform.<br/>
        <em class="cool">Buy your utilities</em> in one place.
      </h2>
      <p class="cta-sub">
        Pay once for the platform. Pay monthly only for the utilities you'd hate to run yourself.
        Or run them all yourself — your call, every time.
      </p>
      <div class="cta-btns">
        <a href="#pricing" class="btn btn-primary btn-lg">Configure Cove + Current <Icon name="arrow" class="arrow" /></a>
        <a href="/pricing" class="btn btn-ghost-light btn-lg">Just Cove for now</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Toggle proof — switch managed/byo
  (() => {
    const opts = document.querySelector<HTMLElement>('[data-proof-options]');
    if (!opts) return;
    const buttons = opts.querySelectorAll<HTMLButtonElement>('[data-mode]');
    const details = document.querySelectorAll<HTMLElement>('.proof-detail[data-mode]');
    const conv = document.querySelector<HTMLElement>('[data-convenience]');

    buttons.forEach(b => b.addEventListener('click', () => {
      const m = b.getAttribute('data-mode');
      buttons.forEach(x => {
        if (x === b) x.setAttribute('data-active', '');
        else x.removeAttribute('data-active');
      });
      details.forEach(d => {
        if (d.getAttribute('data-mode') === m) d.setAttribute('data-active', '');
        else d.removeAttribute('data-active');
      });
      if (conv) conv.textContent = m === 'managed' ? 'Convenience tax: $29.99/mo' : 'Convenience tax: $0/mo';
    }));
  })();
</script>

<style>
  /* Hero */
  .cur-hero {
    position: relative; overflow: hidden;
    padding: 90px 0 100px;
    background: linear-gradient(180deg, #FFFFFF 0%, #F2F8F8 60%, var(--color-bg-2) 100%);
  }
  .cur-hero-bg { position: absolute; inset: 0; width: 100%; height: 100%; opacity: .35; }
  .prod-switch {
    display: inline-flex; gap: 0; padding: 4px; border-radius: 999px;
    background: var(--color-bg-2); border: 1px solid var(--color-line);
    font-family: var(--font-sans); font-size: 13px; font-weight: 600;
  }
  .prod-switch .ps-link {
    padding: 7px 16px; border-radius: 999px; color: var(--color-ink-3);
  }
  .prod-switch .ps-link:hover { color: var(--color-ink); }
  .prod-switch .ps-active {
    padding: 7px 16px; border-radius: 999px;
    background: var(--color-navy-900); color: #fff;
    display: inline-flex; align-items: center; gap: 8px;
  }

  .cur-lede {
    margin: 28px auto 0; font-family: var(--font-serif); font-size: 22px; line-height: 1.45;
    color: var(--color-ink-2); max-width: 760px;
  }
  .cur-sub {
    margin-top: 22px; font-family: var(--font-sans); font-size: 15px; font-weight: 600;
    color: var(--color-teal-600);
  }

  .tier-mini {
    margin: 56px auto 0;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
    max-width: 880px;
  }
  .mini-card {
    padding: 22px; display: flex; align-items: center; gap: 14px; background: #fff;
    transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  }
  .mini-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent);
  }
  .mini-icon {
    flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px;
    display: inline-flex; align-items: center; justify-content: center;
  }
  .mini-text { text-align: left; }
  .mini-name {
    font-family: var(--font-serif); font-weight: 600; font-size: 18px; color: var(--color-ink);
  }
  .mini-up { font-size: 12px; color: var(--color-ink-3); margin-top: 2px; }
  .cur-cta-row {
    margin-top: 36px; display: inline-flex; flex-wrap: wrap; gap: 10px; justify-content: center;
  }

  /* Promise band */
  .promise { padding: 70px 0; background: #fff; border-bottom: 1px solid var(--color-line); }
  .promise-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center;
  }
  .promise-h {
