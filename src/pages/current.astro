---
import Layout from '~/layouts/Layout.astro';
import Mark from '~/components/ui/Mark.astro';
import Icon from '~/components/ui/Icon.astro';
import CurrentGlyph from '~/components/current/CurrentGlyph.astro';
import TierIcon from '~/components/current/TierIcon.astro';
import { CURRENT_TIERS, LAUNCH } from '~/lib/site';

const META = {
  ripple: { accent: '#2BB3B3', icon: 'ripple' as const },
  wave: { accent: '#E76F2A', icon: 'wave' as const },
  surge: { accent: '#7E5BD7', icon: 'spark' as const },
};

const tiers = CURRENT_TIERS.map(t => ({
  ...t,
  accent: META[t.id as keyof typeof META].accent,
  icon: META[t.id as keyof typeof META].icon,
  annualMonthly: Math.round((t.annual / 12) * 100) / 100,
  isHero: 'hero' in t && t.hero,
}));

const wave = tiers.find(t => t.isHero)!;

const FAQ_ITEMS = [
  { q: 'What is the difference between Core and Current?',
    a: 'Core is the portal software you own — a one-time license. Current is the recurring layer that powers it: transactional email, real-time, and the MCP-powered AI agent. You own the house; Current is the intelligence that lives inside and does the work.' },
  { q: 'Why is Wave the recommended tier?',
    a: 'Wave is where the AI happens. It unlocks the full MCP server, so Claude can create tickets, attach assets, update projects, and coordinate across clients using natural language — with Global Notes memory and multi-client scoping. It is the "I need this" moment for most teams.' },
  { q: 'Do the tiers stack?',
    a: 'Yes. Each tier includes everything in the tier below it. Wave includes all of Ripple; Surge includes all of Wave plus the highest rate limits, priority AI queue, advanced memory, and priority support.' },
  { q: 'Monthly or annual?',
    a: 'Either. Annual billing saves roughly 17% versus paying month to month. You can switch or cancel any time — your Core license is permanent regardless.' },
  { q: 'What happens to my data if I cancel Current?',
    a: 'Nothing. Your install keeps running on your Core license. You simply pause the managed email, real-time, and AI services until you resubscribe.' },
  { q: 'Can I start on a lower tier and upgrade later?',
    a: 'Absolutely. Start on Ripple, move up to Wave the moment you want the AI agent, and step to Surge when your usage and team grow. Upgrades are instant.' },
];
---
<Layout
  title="Current — AI-powered services for ClientCove (Ripple, Wave, Surge)"
  description="Current is the recurring layer that powers your ClientCove portal: email and real-time on Ripple, the full MCP AI agent on Wave, and maximum throughput on Surge. From $19/mo."
>
  <!-- Hero -->
  <section class="cur-hero">
    <svg class="cur-hero-bg" viewBox="0 0 1440 600" preserveAspectRatio="none" aria-hidden="true">
      <defs>
        <linearGradient id="cwg" x1="0" x2="1">
          <stop offset="0" stop-color="#2BB3B3" stop-opacity="0"/>
          <stop offset=".5" stop-color="#2BB3B3" stop-opacity=".5"/>
          <stop offset="1" stop-color="#2BB3B3" stop-opacity="0"/>
        </linearGradient>
      </defs>
      {[100, 180, 260, 340, 420, 500].map((y, i) => (
        <path
          d={`M-100 ${y} C 360 ${y - 30 + i*4}, 720 ${y + 30 + i*2}, 1080 ${y - 20}, 1540 ${y + 10}`}
          stroke="url(#cwg)" stroke-width={1 + i * 0.2} fill="none"/>
      ))}
    </svg>

    <div class="container-wide" style="position:relative;text-align:center;">
      <div class="prod-switch">
        <a href="/" class="ps-link">Cove</a>
        <span class="ps-active">
          <CurrentGlyph size={14} />
          Current
        </span>
      </div>

      <div class="eyebrow teal" style="margin-top:32px;justify-content:center;">
        <span class="badge" style="background:rgba(43,179,179,.12);color:var(--color-teal-600);">Recurring AI-powered services</span>
        <span class="label">Three tiers · stacked</span>
      </div>

      <h1 class="cc-display" style="margin-top:24px;max-width:1100px;margin-inline:auto;">
        Cove is the platform.<br/>
        <em class="cool">Current</em> is the AI that does the work.
      </h1>

      <p class="cur-lede">
        Real-time, email, and the MCP-powered AI agent that lives inside your portal — packaged into
        three stacked tiers. Start with Ripple, unlock the AI on Wave, scale up with Surge.
      </p>
      {LAUNCH.active && (
        <div class="cur-sub">
          Every Core license includes your <strong>first month of Wave free</strong> through {LAUNCH.endsShort}.
        </div>
      )}

      <div class="tier-mini">
        {tiers.map(t => (
          <a href={`#${t.id}`} class={`card mini-card ${t.isHero ? 'mini-hero' : ''}`} style={`--accent:${t.accent};`}>
            <span class="mini-icon" style={`background:${t.accent}1A;`}>
              <TierIcon kind={t.icon} color={t.accent} />
            </span>
            <div class="mini-text">
              <div class="mini-name">
                Current <span style={`color:${t.accent};`}>{t.name}</span>
                {t.isHero && <span class="mini-flag">HERO</span>}
              </div>
              <div class="mini-up">${t.monthly}/mo · {t.positioning}</div>
            </div>
          </a>
        ))}
      </div>

      <div class="cur-cta-row">
        <a href="#pricing" class="btn btn-dark btn-lg">See pricing <Icon name="arrow" class="arrow"/></a>
        <a href="#wave" class="btn btn-ghost btn-lg">Why Wave is the hero</a>
      </div>
    </div>
  </section>

  <!-- Wave spotlight — the "holy shit" moment -->
  <section id="wave" class="wave-spot">
    <div class="container-wide wave-grid">
      <div class="wave-copy">
        <div class="eyebrow teal" style="flex-wrap:wrap;">
          <span class="badge" style="background:rgba(231,111,42,.12);color:var(--color-orange);">
            <CurrentGlyph size={11} color="#E76F2A" />
            Current Wave
          </span>
          <span class="label">The hero tier</span>
        </div>
        <h2 class="cc-h2" style="margin-top:14px;">
          Watch Claude do real work<br/>
          <em class="cool">inside your portal.</em>
        </h2>
        <p class="wave-lede">
          Wave turns on the full MCP server. Now Claude can create tickets, attach files, update projects,
          and coordinate across every client — in plain language, without leaving the portal. It remembers
          context with Global Notes and knows which client it's working for.
        </p>
        <div class="wave-feats">
          {wave.feats.map(f => (
            <div class="wave-feat">
              <span class="wf-check"><Icon name="check" /></span>
              {f}
            </div>
          ))}
        </div>
        <div class="wave-price">
          <span class="wp-amt cc-serif">${wave.monthly}</span>
          <span class="wp-period">/mo</span>
          <span class="wp-or">or ${wave.annual}/yr · save ~17%</span>
        </div>
        <a href="#pricing" class="btn btn-primary btn-lg" style="margin-top:24px;">
          Get Wave <Icon name="arrow" class="arrow"/>
        </a>
      </div>

      <div class="wave-demo">
        <div class="demo-bar">
          <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          <div class="demo-addr">portal.acmeagency.com / assistant</div>
        </div>
        <div class="demo-body">
          <div class="msg user">Open a ticket for the Riverside drone shoot and attach the latest footage.</div>
          <div class="msg ai">
            <span class="ai-glyph"><CurrentGlyph size={14} color="#E76F2A" /></span>
            <div>
              <div class="ai-line">✓ Created ticket <strong>#4821</strong> — “Riverside drone shoot”</div>
              <div class="ai-line">✓ Attached <strong>riverside-4k.mp4</strong> (1.2 GB)</div>
              <div class="ai-line">✓ Assigned to <strong>Field Ops</strong>, client scope <strong>Riverside</strong></div>
              <div class="ai-meta">Global Notes updated · multi-client scope verified</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stacked tiers note -->
  <section class="stack-band">
    <div class="container-wide stack-inner">
      <div class="stack-h">Each tier <em class="acc">includes everything</em> below it.</div>
      <div class="stack-flow">
        <span class="sf-pill" style="--c:#2BB3B3;">Ripple</span>
        <Icon name="arrow" />
        <span class="sf-pill" style="--c:#E76F2A;">Wave <em>+ AI agent</em></span>
        <Icon name="arrow" />
        <span class="sf-pill" style="--c:#7E5BD7;">Surge <em>+ scale</em></span>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="pricing-section">
    <div class="container-wide">
      <div style="text-align:center;max-width:680px;margin:0 auto;">
        <div class="eyebrow teal" style="justify-content:center;"><span class="label">Pricing</span></div>
        <h2 class="cc-h2" style="margin-top:14px;">Pick a tier. <em class="cool">Upgrade anytime.</em></h2>
        <div class="bill-toggle" data-billing="monthly" id="bill-toggle" style="margin-top:26px;">
          <button data-period="monthly" aria-pressed="true">Monthly</button>
          <button data-period="annual" aria-pressed="false">Annual · save 17%</button>
        </div>
      </div>

      <div class="price-grid" id="price-grid" data-billing="monthly">
        {tiers.map(t => (
          <div class={`pcard ${t.isHero ? 'pcard-hero' : ''}`} id={t.id} style={`--accent:${t.accent};`}>
            {t.isHero && <span class="pcard-flag">RECOMMENDED</span>}
            <div class="pcard-head">
              <span class="pcard-icon" style={`background:${t.accent}1A;`}>
                <TierIcon kind={t.icon} color={t.accent} size={20} />
              </span>
              <div class="pcard-name">Current {t.name}</div>
            </div>
            <p class="pcard-tag">{t.tagline}</p>
            <div class="pcard-price">
              <span class="pp-monthly">
                <span class="pp-amt cc-serif">${t.monthly}</span><span class="pp-cyc">/mo</span>
              </span>
              <span class="pp-annual">
                <span class="pp-amt cc-serif">${t.annual}</span><span class="pp-cyc">/yr</span>
                <span class="pp-equiv">≈ ${t.annualMonthly}/mo</span>
              </span>
            </div>
            <div class="pcard-pos">{t.positioning}</div>
            <a href="/pricing" class={t.isHero ? 'btn btn-primary' : 'btn btn-dark'} style="width:100%;margin:18px 0;">
              Choose {t.name} <Icon name="arrow" class="arrow"/>
            </a>
            <ul class="pcard-feats">
              {t.feats.map(f => {
                const hl = 'highlight' in t && t.highlight === f;
                return (
                  <li class={hl ? 'pf-hl' : undefined} style={hl ? `background:${t.accent}14;` : undefined}>
                    <span class="pf-check" style={`color:${t.accent};`}><Icon name="check" /></span>
                    {hl ? <strong style={`color:${t.accent};`}>{f}</strong> : f}
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </div>

      <p class="pricing-foot">
        Your ClientCove license is permanent. Current is a separate, optional subscription you can change or cancel any time.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="cur-faq">
    <div class="container-wide faq-grid">
      <div>
        <div class="eyebrow ink"><span class="label">FAQ</span></div>
        <h2 class="cc-h2" style="margin-top:14px;">
          Core, Current, <em class="cool">and the AI.</em>
        </h2>
        <p class="faq-lede">
          The honest version — what you own, what you rent, and where the magic lives.
        </p>
      </div>
      <div class="faq-list">
        {FAQ_ITEMS.map((it, i) => (
          <details class="faq-item" open={i === 0}>
            <summary>
              <span class="faq-q">{it.q}</span>
              <span class="faq-icon"><Icon name="plus" /></span>
            </summary>
            <div class="faq-body">
              <div><p>{it.a}</p></div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="on-dark cur-cta">
    <div class="grid-bg-dark" aria-hidden="true" style="position:absolute;inset:0;opacity:.5;"></div>
    <div class="cta-blob" aria-hidden="true"></div>
    <div class="container-wide" style="position:relative;text-align:center;">
      <div style="display:inline-flex;align-items:center;gap:16px;">
        <Mark size={48} inverse />
        <span style="font-size:28px;color:rgba(255,255,255,.3);">+</span>
        <CurrentGlyph size={44} />
      </div>
      <h2 class="cc-h1" style="margin-top:28px;color:#fff;">
        Own the platform.<br/>
        <em class="cool">Let the AI do the work.</em>
      </h2>
      <p class="cta-sub">
        Buy Core once. Add Wave and watch Claude run your client operations from inside the portal.
      </p>
      <div class="cta-btns">
        <a href="/pricing" class="btn btn-primary btn-lg">Buy Core + Current <Icon name="arrow" class="arrow" /></a>
        <a href="#wave" class="btn btn-ghost-light btn-lg">See Wave in action</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const toggle = document.getElementById('bill-toggle');
  const grid = document.getElementById('price-grid');
  if (toggle && grid) {
    toggle.querySelectorAll<HTMLButtonElement>('button').forEach(btn => {
      btn.addEventListener('click', () => {
        const p = btn.getAttribute('data-period') || 'monthly';
        toggle.setAttribute('data-billing', p);
        grid.setAttribute('data-billing', p);
        toggle.querySelectorAll<HTMLButtonElement>('button').forEach(b => {
          b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
        });
      });
    });
  }
</script>

<style>
  /* Hero */
  .cur-hero {
    position: relative; overflow: hidden;
    padding: 90px 0 100px;
    background: linear-gradient(180deg, #FFFFFF 0%, #F2F8F8 60%, var(--color-bg-2) 100%);
  }
  .cur-hero-bg { position: absolute; inset: 0; width: 100%; height: 100%; opacity: .35; }
  .prod-switch {
    display: inline-flex; gap: 0; padding: 4px; border-radius: 999px;
    background: var(--color-bg-2); border: 1px solid var(--color-line);
    font-family: var(--font-sans); font-size: 13px; font-weight: 600;
  }
  .prod-switch .ps-link { padding: 7px 16px; border-radius: 999px; color: var(--color-ink-3); }
  .prod-switch .ps-link:hover { color: var(--color-ink); }
  .prod-switch .ps-active {
    padding: 7px 16px; border-radius: 999px;
    background: var(--color-navy-900); color: #fff;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .cur-lede {
    margin: 28px auto 0; font-family: var(--font-serif); font-size: 22px; line-height: 1.45;
    color: var(--color-ink-2); max-width: 780px;
  }
  .cur-sub {
    margin-top: 22px; font-family: var(--font-sans); font-size: 15px; font-weight: 600;
    color: var(--color-teal-600);
  }
  .cur-sub strong { color: var(--color-orange); }

  .tier-mini {
    margin: 56px auto 0;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
    max-width: 920px;
  }
  .mini-card {
    padding: 22px; display: flex; align-items: center; gap: 14px; background: #fff;
    transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  }
  .mini-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: var(--accent); }
  .mini-hero { border-color: var(--accent); box-shadow: 0 10px 30px -12px rgba(231,111,42,.4); }
  .mini-icon {
    flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px;
    display: inline-flex; align-items: center; justify-content: center;
  }
  .mini-text { text-align: left; }
  .mini-name {
    font-family: var(--font-serif); font-weight: 600; font-size: 18px; color: var(--color-ink);
    display: flex; align-items: center; gap: 8px;
  }
  .mini-flag {
    font-family: var(--font-sans); font-size: 8.5px; font-weight: 700; letter-spacing: .08em;
    padding: 2px 6px; border-radius: 4px; background: var(--color-orange); color: #fff;
  }
  .mini-up { font-size: 12px; color: var(--color-ink-3); margin-top: 2px; }
  .cur-cta-row { margin-top: 36px; display: inline-flex; flex-wrap: wrap; gap: 10px; justify-content: center; }

  /* Wave spotlight */
  .wave-spot { padding: 110px 0; background: #fff; border-bottom: 1px solid var(--color-line); }
  .wave-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
  .wave-lede { margin-top: 18px; font-size: 16.5px; line-height: 1.65; color: var(--color-ink-2); max-width: 520px; }
  .wave-feats { margin-top: 24px; display: flex; flex-direction: column; gap: 10px; }
  .wave-feat { display: flex; gap: 10px; align-items: flex-start; font-size: 14.5px; color: var(--color-ink-2); }
  .wf-check {
    flex-shrink: 0; width: 20px; height: 20px; border-radius: 999px;
    background: rgba(231,111,42,.14); color: var(--color-orange);
    display: inline-flex; align-items: center; justify-content: center; margin-top: 1px;
  }
  .wave-price { margin-top: 28px; display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; }
  .wp-amt { font-size: 48px; font-weight: 700; color: var(--color-ink); line-height: 1; }
  .wp-period { font-size: 16px; color: var(--color-ink-3); }
  .wp-or { font-size: 13px; color: var(--color-ink-3); margin-left: 6px; }

  .wave-demo {
    background: var(--color-navy-900); border-radius: 16px; overflow: hidden;
    box-shadow: 0 30px 60px -22px rgba(10,31,46,.5);
  }
  .demo-bar {
    display: flex; align-items: center; gap: 8px; padding: 14px 18px;
    background: rgba(255,255,255,.04); border-bottom: 1px solid rgba(255,255,255,.08);
  }
  .demo-bar .dot { width: 10px; height: 10px; border-radius: 999px; background: rgba(255,255,255,.18); }
  .demo-addr {
    margin-left: 14px; padding: 4px 12px; background: rgba(255,255,255,.06); border-radius: 6px;
    font-family: var(--font-mono); font-size: 11px; color: rgba(255,255,255,.6);
  }
  .demo-body { padding: 26px; display: flex; flex-direction: column; gap: 16px; }
  .msg { font-size: 14px; line-height: 1.5; border-radius: 12px; padding: 14px 16px; }
  .msg.user { background: rgba(255,255,255,.08); color: #fff; align-self: flex-end; max-width: 85%; }
  .msg.ai {
    background: rgba(231,111,42,.1); border: 1px solid rgba(231,111,42,.25);
    color: rgba(255,255,255,.92); display: flex; gap: 12px; align-items: flex-start; max-width: 92%;
  }
  .ai-glyph { flex-shrink: 0; margin-top: 2px; }
  .ai-line { font-family: var(--font-mono); font-size: 12.5px; color: rgba(255,255,255,.85); margin-bottom: 4px; }
  .ai-line strong { color: #fff; }
  .ai-meta { margin-top: 8px; font-size: 11px; color: var(--color-teal); }

  /* Stacked band */
  .stack-band { padding: 56px 0; background: var(--color-bg-2); }
  .stack-inner { display: flex; align-items: center; justify-content: center; gap: 40px; flex-wrap: wrap; text-align: center; }
  .stack-h { font-family: var(--font-serif); font-size: 26px; font-weight: 500; color: var(--color-ink); }
  .stack-flow { display: inline-flex; align-items: center; gap: 14px; flex-wrap: wrap; color: var(--color-ink-3); }
  .sf-pill {
    display: inline-flex; align-items: baseline; gap: 6px;
    padding: 8px 16px; border-radius: 999px; background: #fff;
    border: 1.5px solid var(--c); color: var(--c); font-weight: 700; font-size: 14px;
  }
  .sf-pill em { font-style: normal; font-weight: 500; font-size: 12px; opacity: .8; }

  /* Pricing */
  .pricing-section { padding: 110px 0; background: #fff; }
  .bill-toggle {
    display: inline-flex; padding: 4px; background: var(--color-bg-2);
    border: 1px solid var(--color-line); border-radius: 999px;
  }
  .bill-toggle button {
    background: transparent; border: 0; padding: 8px 18px; border-radius: 999px;
    font-size: 13.5px; font-weight: 600; color: var(--color-ink-2);
    cursor: pointer; transition: background .2s ease, color .2s ease; font-family: inherit;
  }
  .bill-toggle button[aria-pressed="true"] { background: var(--color-navy-900); color: #fff; }

  .price-grid {
    margin: 48px auto 0; display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 18px; max-width: 1000px; align-items: start;
  }
  .pcard {
    position: relative; background: #fff; border: 1px solid var(--color-line);
    border-radius: 16px; padding: 30px 26px; box-shadow: var(--shadow-sm);
  }
  .pcard-hero {
    border-color: var(--accent); box-shadow: 0 30px 60px -24px rgba(231,111,42,.45);
    transform: translateY(-8px);
  }
  .pcard-flag {
    position: absolute; top: -11px; left: 50%; transform: translateX(-50%);
    font-size: 9.5px; font-weight: 700; letter-spacing: .08em;
    padding: 5px 12px; border-radius: 999px; background: var(--color-orange); color: #fff;
  }
  .pcard-head { display: flex; align-items: center; gap: 12px; }
  .pcard-icon { width: 38px; height: 38px; border-radius: 10px; display: inline-flex; align-items: center; justify-content: center; }
  .pcard-name { font-family: var(--font-serif); font-weight: 600; font-size: 19px; color: var(--color-ink); }
  .pcard-tag { margin-top: 14px; font-size: 13.5px; color: var(--color-ink-2); line-height: 1.5; min-height: 40px; }
  .pcard-price { margin-top: 16px; }
  .pp-amt { font-size: 44px; font-weight: 700; color: var(--color-ink); line-height: 1; }
  .pp-cyc { font-size: 14px; color: var(--color-ink-3); margin-left: 2px; }
  .pp-equiv { display: block; font-size: 12px; color: var(--color-ink-3); margin-top: 4px; }
  .pp-annual { display: none; }
  .price-grid[data-billing="annual"] .pp-monthly { display: none; }
  .price-grid[data-billing="annual"] .pp-annual { display: block; }
  .pcard-pos {
    margin-top: 10px; font-size: 11px; font-weight: 600; letter-spacing: .08em;
    text-transform: uppercase; color: var(--color-ink-3);
  }
  .pcard-feats { list-style: none; padding: 16px 0 0; margin: 0; border-top: 1px solid var(--color-line-2); display: flex; flex-direction: column; gap: 10px; }
  .pcard-feats li { display: flex; gap: 9px; font-size: 13.5px; color: var(--color-ink-2); line-height: 1.45; }
  .pcard-feats li.pf-hl { font-weight: 600; padding: 7px 10px; margin: -3px -10px; border-radius: 8px; }
  .pf-check { flex-shrink: 0; margin-top: 1px; }
  .pricing-foot { margin: 36px auto 0; max-width: 640px; text-align: center; font-size: 13px; color: var(--color-ink-3); }

  /* FAQ */
  .cur-faq { padding: 120px 0; background: var(--color-bg-2); }
