---
import Layout from '~/layouts/Layout.astro';
import PageHero from '~/components/PageHero.astro';
import Icon from '~/components/ui/Icon.astro';
import { SITE } from '~/lib/site';

const channels = [
  { h: 'Sales & licensing', e: 'sales@clientcove.io', d: 'Pre-purchase questions, custom installs, volume licensing.' },
  { h: 'Customer support', e: 'support@clientcove.io', d: 'For licensed customers — bugs, questions, migration help.' },
  { h: 'Press & partnerships', e: 'hello@clientcove.io', d: 'Coverage, integrations, agency partnerships.' },
];
---
<Layout
  title="Contact — Talk to the team"
  description="Reach the ClientCove team. We answer our own email — usually within one business day."
>
  <PageHero
    eyebrow="CONTACT"
    title="Talk to <em class='acc'>the team.</em>"
    subtitle="We're a small team in California. We answer our own email — usually within one business day."
  />

  <section class="sect" style="padding-top:0;">
    <div class="container contact-grid">
      <form class="contact-form reveal" name="contact" method="POST" action="/api/contact" data-form>
        <div class="row">
          <label>
            <span>Name</span>
            <input type="text" name="name" required autocomplete="name" />
          </label>
          <label>
            <span>Email</span>
            <input type="email" name="email" required autocomplete="email" />
          </label>
        </div>
        <label>
          <span>Company</span>
          <input type="text" name="company" autocomplete="organization" />
        </label>
        <label>
          <span>What can we help with?</span>
          <select name="topic" required>
            <option value="">Pick one…</option>
            <option>Pre-purchase questions</option>
            <option>Volume / agency licensing</option>
            <option>Migration help</option>
            <option>Press / partnerships</option>
            <option>Other</option>
          </select>
        </label>
        <label>
          <span>Message</span>
          <textarea name="message" rows="5" required></textarea>
        </label>
        <button type="submit" class="btn btn-primary btn-lg" style="width:100%;">
          Send message <Icon name="arrow" class="arrow" />
        </button>
        <p class="form-status" data-status hidden></p>
        <p class="fineprint">
          By sending you agree to our <a href="/privacy">privacy policy</a>. We'll never share your email.
        </p>
      </form>

      <aside class="contact-side reveal">
        <div class="card" style="padding:28px;">
          <h2 class="cc-h3" style="margin-bottom:14px;">Reach the right team</h2>
          <ul>
            {channels.map(c => (
              <li>
                <div class="ch-h">{c.h}</div>
                <a href={`mailto:${c.e}`} class="ch-e"><Icon name="mail" /> {c.e}</a>
                <p>{c.d}</p>
              </li>
            ))}
          </ul>
        </div>

        <div class="card" style="padding:28px;margin-top:16px;background:var(--color-navy-900);color:#fff;border-color:var(--color-navy-700);">
          <div style="font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,.55);margin-bottom:10px;">Office</div>
          <p style="font-size:15px;line-height:1.6;color:rgba(255,255,255,.9);margin:0;">
            ClientCove HQ<br />
            San Diego, California, USA<br />
            Hours: Mon–Fri · 9–5 PT
          </p>
          <a href={`mailto:${SITE.email}`} class="lnk" style="margin-top:16px;color:#fff;">
            <Icon name="mail" /> {SITE.email} <Icon name="arrow" />
          </a>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<script>
  // Best-effort progressive enhancement: prevent form post and show a friendly message.
  // Wire to a real backend (Resend, Loops, Beehiiv, etc.) later.
  const form = document.querySelector<HTMLFormElement>('[data-form]');
  const status = document.querySelector<HTMLElement>('[data-status]');
  if (form && status) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      status.hidden = false;
      status.textContent = 'Thanks — we got it. We will reply within one business day.';
      status.style.color = 'var(--color-teal-600)';
      form.reset();
    });
  }
</script>

<style>
  .contact-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 32px; align-items: flex-start; }
  .contact-form {
    background: #fff; border: 1px solid var(--color-line);
    border-radius: 16px; padding: 32px;
    display: flex; flex-direction: column; gap: 14px;
  }
  .contact-form .row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .contact-form label { display: flex; flex-direction: column; gap: 6px; font-size: 13px; font-weight: 500; color: var(--color-ink-2); }
  .contact-form input, .contact-form textarea, .contact-form select {
    font: inherit; font-size: 14.5px; color: var(--color-ink);
    padding: 11px 14px; border: 1px solid var(--color-line);
    background: #fff; border-radius: 8px;
    outline: none; transition: border-color .15s ease, box-shadow .15s ease;
  }
  .contact-form input:focus, .contact-form textarea:focus, .contact-form select:focus {
    border-color: var(--color-orange);
    box-shadow: 0 0 0 3px var(--color-orange-50);
  }
  .contact-form textarea { resize: vertical; min-height: 110px; }
  .form-status { font-size: 14px; margin: 4px 0 0; }
  .fineprint { font-size: 12px; color: var(--color-ink-3); margin: 0; }

  .contact-side ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 18px; }
  .contact-side li + li { padding-top: 18px; border-top: 1px solid var(--color-line-2); }
  .ch-h { font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink-3); margin-bottom: 6px; }
  .ch-e { display: inline-flex; align-items: center; gap: 6px; color: var(--color-orange); font-weight: 600; font-size: 14px; }
  .contact-side p { font-size: 13px; color: var(--color-ink-2); line-height: 1.55; margin: 6px 0 0; }

  @media (max-width: 880px) {
    .contact-grid { grid-template-columns: 1fr; }
    .contact-form .row { grid-template-columns: 1fr; }
  }
</style>
