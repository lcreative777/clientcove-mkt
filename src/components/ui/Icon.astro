---
interface Props {
  name: 'arrow' | 'check' | 'x' | 'plus' | 'caret' | 'bolt' | 'menu' | 'close' | 'mail' | 'shield' | 'globe';
  class?: string;
  size?: number;
}
const { name, class: className = '', size } = Astro.props;
const w = size ?? (name === 'arrow' ? 14 : name === 'check' || name === 'x' ? 11 : name === 'plus' ? 13 : name === 'caret' ? 9 : 16);
---
{name === 'arrow' && (
  <svg width={w} height={w} viewBox="0 0 16 16" fill="none" class={className} aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
)}
{name === 'check' && (
  <svg width={w} height={w} viewBox="0 0 12 12" fill="none" class={className} aria-hidden="true"><path d="M2.5 6.5L5 9l4.5-5.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
)}
{name === 'x' && (
  <svg width={w} height={w} viewBox="0 0 12 12" fill="none" class={className} aria-hidden="true"><path d="M3 3l6 6M9 3l-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
)}
{name === 'plus' && (
  <svg width={w} height={w} viewBox="0 0 14 14" fill="none" class={className} aria-hidden="true"><path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
)}
{name === 'caret' && (
  <svg width={w} height={w} viewBox="0 0 10 10" fill="none" class={className} aria-hidden="true"><path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
)}
{name === 'bolt' && (
  <svg width={w} height={w} viewBox="0 0 16 16" fill="none" class={className} aria-hidden="true"><path d="M9 1L3 9h4l-1 6 6-8H8l1-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
)}
{name === 'menu' && (
  <svg width={w} height={w} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
)}
{name === 'close' && (
  <svg width={w} height={w} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
)}
{name === 'mail' && (
  <svg width={w} height={w} viewBox="0 0 16 16" fill="none" class={className} aria-hidden="true"><path d="M2 4h12v8H2zM2 4l6 5 6-5" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
)}
{name === 'shield' && (
  <svg width={w} height={w} viewBox="0 0 16 16" fill="none" class={className} aria-hidden="true"><path d="M8 1l6 2v5c0 4-3 6.5-6 7-3-.5-6-3-6-7V3l6-2z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
)}
{name === 'globe' && (
  <svg width={w} height={w} viewBox="0 0 16 16" fill="none" class={className} aria-hidden="true"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.4"/><path d="M2 8h12M8 2c2 2 2 10 0 12M8 2c-2 2-2 10 0 12" stroke="currentColor" stroke-width="1.4"/></svg>
)}
