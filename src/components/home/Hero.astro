---
import Icon from '~/components/ui/Icon.astro';
import HeroTour from '~/components/home/HeroTour.astro';
---
<section class="hero">
  <svg class="hero-mesh" viewBox="0 0 1600 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <defs>
      <radialGradient id="g1" cx="20%" cy="20%" r="50%">
        <stop offset="0%" stop-color="#E76F2A" stop-opacity=".35" />
        <stop offset="100%" stop-color="#E76F2A" stop-opacity="0" />
      </radialGradient>
      <radialGradient id="g2" cx="80%" cy="10%" r="50%">
        <stop offset="0%" stop-color="#2BB3B3" stop-opacity=".28" />
        <stop offset="100%" stop-color="#2BB3B3" stop-opacity="0" />
      </radialGradient>
      <radialGradient id="g3" cx="60%" cy="80%" r="55%">
        <stop offset="0%" stop-color="#7E5BD7" stop-opacity=".2" />
        <stop offset="100%" stop-color="#7E5BD7" stop-opacity="0" />
      </radialGradient>
      <radialGradient id="g4" cx="10%" cy="90%" r="40%">
        <stop offset="0%" stop-color="#0A1F2E" stop-opacity=".18" />
        <stop offset="100%" stop-color="#0A1F2E" stop-opacity="0" />
      </radialGradient>
      <linearGradient id="fade" x1="0" x2="0" y1="0" y2="1">
        <stop offset="0%" stop-color="#fff" stop-opacity="0" />
        <stop offset="100%" stop-color="#fff" stop-opacity="1" />
      </linearGradient>
    </defs>
    <rect width="1600" height="900" fill="url(#g1)" />
    <rect width="1600" height="900" fill="url(#g2)" />
    <rect width="1600" height="900" fill="url(#g3)" />
    <rect width="1600" height="900" fill="url(#g4)" />
    <rect x="0" y="600" width="1600" height="300" fill="url(#fade)" />
  </svg>
  <div class="grid-bg hero-grid" aria-hidden="true"></div>

  <div class="container-wide hero-inner">
    <div class="hero-copy">
      <div class="reveal" style="margin-bottom:24px;">
        <span class="pill warm">
          <span class="dot"></span>
          Coming soon — MCP server + Claude Code extensions
        </span>
      </div>

      <h1 class="cc-display reveal hero-h1">
        Run your entire business from <em class="acc">one&nbsp;portal</em> you actually own.
      </h1>

      <p class="reveal hero-lede">
        Centralize clients, projects, and knowledge into your branded hub.
        <strong>Connected. Intelligent.</strong> Built to scale with AI — and fully yours to extend.
      </p>

      <p class="reveal hero-sub">
        Every module your business needs — <strong>white-label</strong>: edit the design
        and brand as your own.
      </p>

      <ul class="reveal hero-pills" aria-label="Included modules">
        <li>Intake forms</li>
        <li>Contracts &amp; e-sign</li>
        <li>Project Management</li>
        <li>Tasks &amp; time tracking</li>
        <li>Tickets</li>
        <li>Digital asset management</li>
        <li>Client asset management</li>
        <li>Send large file transfers</li>
        <li>Client invoicing + Stripe</li>
        <li>Subscription billing</li>
        <li>AI Company Brain</li>
      </ul>

      <p class="reveal hero-sub-bridge">
        
        <strong>Transform Your Business with Fully Customizable AI Power</strong>
      </p>

      <p class="reveal hero-kicker">Why rent SaaS when you can own?</p>

      <div class="reveal hero-ctas">
        <a href="/pricing" class="btn btn-primary btn-lg">
          Buy ClientCove — $349 <Icon name="arrow" class="arrow" />
        </a>
        <a href="#tour" class="btn btn-ghost btn-lg">
          Live product tour <Icon name="arrow" class="arrow" />
        </a>
      </div>

      <ul class="reveal trust-bar" aria-label="Trust">
        <li><span class="check"><Icon name="check" /></span> Extends with Claude Code</li>
        <li><span class="check"><Icon name="check" /></span> Unlimited clients & users</li>
        <li><span class="check"><Icon name="check" /></span> 30-day money back</li>
      </ul>
    </div>

    <div class="hero-mock">
      <HeroTour />
    </div>
  </div>
</section>

<style>
  .hero { position: relative; padding: 40px 0 160px; overflow: hidden; }
  .hero-mesh { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; }
  .hero-grid {
    position: absolute; inset: 0; z-index: 0; opacity: .6;
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, black 30%, transparent 80%);
            mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, black 30%, transparent 80%);
  }
  .hero-inner { position: relative; z-index: 1; }
  .hero-copy { text-align: center; max-width: 1100px; margin: 0 auto; padding: 80px 0 70px; }
  .hero-h1 {
    font-size: clamp(42px, 6.4vw, 84px);
    line-height: 1.04;
    letter-spacing: -0.028em;
  }
  .hero-lede {
    font-size: 21px; line-height: 1.45; color: var(--color-ink);
    max-width: 740px; margin: 26px auto 0; text-wrap: pretty;
  }
  .hero-lede strong { font-weight: 600; color: var(--color-ink); }
  .hero-sub {
    font-size: 15.5px; line-height: 1.55; color: var(--color-ink-3);
    max-width: 640px; margin: 14px auto 0; text-wrap: pretty;
  }
  .hero-pills {
    list-style: none; padding: 0;
    margin: 22px auto 0; max-width: 820px;
    display: flex; flex-wrap: wrap; justify-content: center; gap: 7px;
  }
  .hero-pills li {
    font-size: 14px; font-weight: 500; color: var(--color-ink);
    padding: 8px 14px;
    background: rgba(255,255,255,.75);
    border: 1px solid var(--color-line);
    border-radius: 999px;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    display: inline-flex; align-items: center; gap: 8px;
    transition: border-color .15s ease, transform .15s ease;
  }
  .hero-pills li:hover { border-color: var(--color-ink-3); transform: translateY(-1px); }
  .hero-pills li::before {
    content: '';
    display: inline-block; width: 6px; height: 6px; border-radius: 999px;
    background: var(--color-teal-600);
    flex-shrink: 0;
  }
  .hero-pills li:nth-child(5n+1)::before { background: var(--color-orange); }
  .hero-pills li:nth-child(5n+2)::before { background: var(--color-teal-600); }
  .hero-pills li:nth-child(5n+3)::before { background: var(--color-violet); }
  .hero-pills li:nth-child(5n+4)::before { background: var(--color-navy-900); }
  .hero-pills li:nth-child(5n+5)::before { background: var(--color-green); }
  .hero-sub-bridge {
    font-size: 16px; line-height: 1.55; color: var(--color-ink-2);
    max-width: 620px; margin: 24px auto 0; text-wrap: pretty;
  }
  .hero-kicker {
    font-family: var(--font-serif);
    font-size: 22px; font-style: italic; font-weight: 600;
    color: var(--color-ink);
    margin: 18px auto 0; max-width: 700px;
    text-wrap: balance;
  }
  .hero-ctas { display: flex; gap: 10px; justify-content: center; margin-top: 28px; flex-wrap: wrap; }
  .trust-bar {
    list-style: none; padding: 0; margin: 26px auto 0;
    display: inline-flex; align-items: center; gap: 22px;
    font-size: 13px; color: var(--color-ink-3);
    flex-wrap: wrap; justify-content: center;
  }
  .trust-bar li { display: inline-flex; align-items: center; gap: 6px; }

  /* Mock wrapper — sizing/margin handled; frame + internals are in HeroTour.astro */
  .hero-mock { position: relative; width: 100%; max-width: 1180px; margin: 0 auto; }

  @media (max-width: 780px) {
    .hero { padding-bottom: 80px; }
    .hero-copy { padding: 40px 0 50px; }
  }
</style>
