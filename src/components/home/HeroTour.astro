<!-- ─── Hero animated product tour ─────────────────────────────────────────
     LCP strategy: Projects panel is static HTML (no JS needed).
     Tasks + Resources panels live in <template> elements — parsed but never
     painted. Cycling logic fires inside requestIdleCallback after first paint.
──────────────────────────────────────────────────────────────────────────── -->

<div class="hero-tour" id="hero-tour">
  <!-- gradient glow border -->
  <div class="ht-glow" aria-hidden="true"></div>

  <div class="ht-frame">
    <!-- ── Browser chrome ── -->
    <div class="ht-bar">
      <div class="ht-dots">
        <span style="background:#FF5F57"></span>
        <span style="background:#FEBC2E"></span>
        <span style="background:#28C840"></span>
      </div>
      <div class="ht-addr">
        <svg width="9" height="9" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M3 6V4a3 3 0 016 0v2M3 6h6v4H3V6z" stroke="currentColor" stroke-width="1.2"/></svg>
        portal.<strong>acmeagency</strong>.com/<span id="ht-urlpath">projects/acme-website</span>
      </div>
      <div style="width:60px"></div>
    </div>

    <!-- ── KPI ticker ── -->
    <div class="ht-kpis num">
      <div><span class="ht-lbl">Active tickets</span><div class="ht-val"><span class="cc-serif">247</span><span class="ht-delta">▲ +8</span></div></div>
      <div><span class="ht-lbl">Open invoices</span><div class="ht-val"><span class="cc-serif">$48.2k</span><span class="ht-delta">▲ +$1.2k</span></div></div>
      <div><span class="ht-lbl">Hours logged</span><div class="ht-val"><span class="cc-serif">184.5</span><span class="ht-delta">▲ +0.5</span></div></div>
      <div><span class="ht-lbl">On-time delivery</span><div class="ht-val"><span class="cc-serif">94%</span><span class="ht-delta">▲ +1%</span></div></div>
    </div>

    <!-- ── App layout ── -->
    <div class="ht-app">
      <!-- Sidebar nav -->
      <aside class="ht-sidebar" id="ht-sidebar" data-active="projects">
        <div class="ht-ws-head">Workspace</div>
        <div class="ht-ws-card">
          <span class="ht-ws-thumb"></span>
          Acme Agency
