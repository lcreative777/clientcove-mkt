        </div>
        <div class="ht-nav-item" data-id="dashboard">Dashboard</div>
        <div class="ht-nav-item" data-id="tickets">Tickets <span class="ht-nb">12</span></div>
        <div class="ht-nav-item" data-id="projects">Projects <span class="ht-nb">5</span></div>
        <div class="ht-nav-item" data-id="tasks">My Tasks <span class="ht-nb">11</span></div>
        <div class="ht-nav-item" data-id="resources">Resources</div>
        <div class="ht-nav-item" data-id="clients">Clients</div>
        <div class="ht-nav-item" data-id="contracts">Contracts <span class="ht-nb">4</span></div>
        <div class="ht-nav-item" data-id="invoices">Invoices <span class="ht-nb">8</span></div>
      </aside>

      <!-- Swappable canvas — Projects panel rendered immediately (LCP) -->
