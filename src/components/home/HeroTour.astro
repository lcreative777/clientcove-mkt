  /* ── Frame & glow ─────────────────────────────────────────────────── */
  .hero-tour { position: relative; width: 100%; max-width: 1180px; margin: 0 auto; }
  .ht-glow {
    position: absolute; inset: -1px; border-radius: 17px;
    background: linear-gradient(135deg, rgba(231,111,42,.5), rgba(43,179,179,.5) 50%, rgba(126,91,215,.5));
    filter: blur(2px); opacity: .6; pointer-events: none;
  }
  .ht-frame {
    position: relative; border-radius: 16px; overflow: hidden;
    background: #fff; border: 1px solid var(--color-line); box-shadow: var(--shadow-xl);
  }

  /* ── Browser bar ─────────────────────────────────────────────────── */
  .ht-bar {
    height: 36px; background: #F6F8FA; border-bottom: 1px solid var(--color-line);
    display: flex; align-items: center; padding: 0 14px; gap: 10px;
