    --orange-600: var(--color-orange-600);
    --teal:       var(--color-teal);
    --teal-600:   var(--color-teal-600);
    --teal-50:    var(--color-teal-50);
    --violet:     var(--color-violet);
    --green:      var(--color-green);
    --ink:        var(--color-ink);
    --ink-2:      var(--color-ink-2);
    --ink-3:      var(--color-ink-3);
    --ink-4:      var(--color-ink-4);
    --line:       var(--color-line);
    --line-2:     var(--color-line-2);
    --navy-50:    var(--color-navy-50);
    --navy-900:   var(--color-navy-900);
    --bg-2:       var(--color-bg-2);
    --serif:      var(--font-serif);
  }

  /* ── Keyframe animations (verbatim from product tour) ──────────────── */
  @keyframes heroViewIn    { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }
  @keyframes heroModalIn   { from { opacity: 0; transform: translate(-50%, -46%) scale(.97); } to { opacity: 1; transform: translate(-50%, -50%) scale(1); } }
  @keyframes heroFadeIn    { from { opacity: 0; } to { opacity: 1; } }
  @keyframes heroRowIn     { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: none; } }
  @keyframes heroCaret     { 0%, 45% { opacity: 1; } 55%, 100% { opacity: 0; } }
  @keyframes heroNavFlash  { from { opacity: 0; transform: scaleY(.2); } to { opacity: 1; transform: scaleY(1); } }
  @keyframes heroDrop {
    0%   { transform: translate(420px, -40px) rotate(7deg) scale(.92); opacity: 0; }
    55%  { opacity: 1; }
    82%  { transform: translate(-6px, 5px) rotate(-1.5deg) scale(1.015); }
    100% { transform: translate(0,0) rotate(0) scale(1); opacity: 1; }
  }
  @keyframes heroAddedPulse { 0% { box-shadow: 0 0 0 0 rgba(43,179,179,.5); } 100% { box-shadow: 0 0 0 12px rgba(43,179,179,0); } }
  @keyframes htFloatTR {
    0%, 100% { transform: rotate(3deg) translateY(0); }
    50%       { transform: rotate(3deg) translateY(-14px); }
  }
  @keyframes htFloatBL {
    0%, 100% { transform: rotate(-3deg) translateY(0); }
    50%       { transform: rotate(-3deg) translateY(-14px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ht-view, .ht-modal-in, .ht-backdrop { animation: none !important; }
    .ht-float-tr, .ht-float-bl { animation: none !important; }
