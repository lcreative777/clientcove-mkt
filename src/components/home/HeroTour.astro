  .ht-stat-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 7px; font-size: 10px; color: var(--color-ink-3); }
  .ht-stat-val { font-size: 10.5px; font-weight: 700; padding: 1px 8px; border-radius: 5px; }
  .ht-tag { display: inline-flex; align-items: center; gap: 5px; font-size: 9px; font-weight: 600; padding: 3px 7px; border-radius: 5px; background: var(--color-bg-2); color: var(--color-ink-2); }
  .ht-tag span:first-child { width: 6px; height: 6px; border-radius: 999px; }
  /* typing input */
  .ht-type-input {
    display: flex; align-items: center; gap: 8px; margin-bottom: 8px; animation: heroRowIn .3s ease;
  }
  .ht-type-field {
    flex: 1; display: flex; align-items: center; height: 32px; padding: 0 10px;
    border: 1.5px solid #6366F1; border-radius: 8px; background: #fff;
    font-size: 11px; color: var(--color-ink); min-width: 0;
  }
  .ht-caret { display: inline-block; width: 1.5px; height: 14px; background: #6366F1; margin-left: 1px; flex-shrink: 0; animation: heroCaret .9s steps(1) infinite; }
  .ht-add-btn-blue { font-size: 11px; font-weight: 600; color: #fff; background: #6366F1; border-radius: 7px; padding: 7px 16px; }
  /* new task row highlight */
  .ht-task-new { animation: heroRowIn .4s ease; background: rgba(99,102,241,.06); border-radius: 6px; }

  /* ── Resources view ──────────────────────────────────────────────── */
  .ht-res-tree { border-right: 1px solid var(--color-line-2); padding: 12px; background: #FCFCFD; overflow: hidden; }
  .ht-res-tree-hd { font-size: 10px; font-weight: 700; letter-spacing: .1em; color: var(--color-ink-3); margin-bottom: 8px; }
  .ht-res-search { font-size: 9.5px; color: var(--color-ink-4); border: 1px solid var(--color-line); border-radius: 6px; padding: 5px 8px; margin-bottom: 10px; }
  .ht-res-section { font-size: 8.5px; font-weight: 700; letter-spacing: .1em; color: var(--color-ink-4); margin: 10px 0 5px; }
  .ht-res-item { display: flex; align-items: center; gap: 6px; padding: 5px 8px; border-radius: 5px; margin-bottom: 1px; font-size: 10.5px; font-weight: 500; color: var(--color-ink-2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ht-res-strong { font-weight: 600; }
  .ht-res-active { background: var(--color-teal-50); color: var(--color-teal-600); font-weight: 600; }
  .ht-lock { margin-left: auto; opacity: .4; font-size: 8px; }
  .ht-add-btn { font-size: 10px; font-weight: 600; color: #fff; background: var(--color-violet); padding: 4px 10px; border-radius: 6px; }
  .ht-folder-card { flex: 1; display: flex; align-items: center; gap: 8px; background: #fff; border: 1px solid var(--color-line-2); border-radius: 8px; padding: 9px 10px; }
  .ht-file-card { width: 132px; background: #fff; border: 1px solid var(--color-line-2); border-radius: 8px; padding: 10px; box-shadow: var(--shadow-sm); }
  .ht-file-icon { display: flex; justify-content: center; padding: 8px 0 12px; }
  .ht-file-added { animation: heroAddedPulse 1s ease-out; }

  /* ── Floating cards ──────────────────────────────────────────────── */
  .ht-float {
    position: absolute; background: #fff;
    border: 1px solid var(--color-line); border-radius: 12px;
    padding: 14px; box-shadow: var(--shadow-lg); z-index: 2;
  }
  .ht-float-tr { width: 270px; top: -38px; right: -38px; transform: rotate(3deg); animation: htFloatTR 5s ease-in-out infinite; }
  .ht-float-bl { width: 256px; bottom: -36px; left: -50px; transform: rotate(-3deg); padding: 13px; z-index: 30; animation: htFloatBL 5s ease-in-out infinite 2.5s; }
  .ht-fc-head { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
  .ht-fc-ic { width: 32px; height: 32px; border-radius: 8px; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .ht-float p { font-size: 11px; color: var(--color-ink-3); line-height: 1.5; padding-left: 42px; margin: 0; }
  .ht-badge-status { font-size: 9.5px; font-weight: 700; padding: 3px 7px; color: #fff; border-radius: 4px; }
  .ht-signed-row { display: flex; justify-content: space-between; align-items: center; padding-top: 8px; border-top: 1px solid var(--color-line-2); }

  /* ── Responsive ──────────────────────────────────────────────────── */
  @media (max-width: 1100px) {
    .ht-float { display: none; }
  }
  @media (max-width: 900px) {
    .ht-kpis { grid-template-columns: repeat(2, 1fr); }
    .ht-kpis > div:nth-child(2) { border-right: none; }
    .ht-kpis > div:nth-child(1),
    .ht-kpis > div:nth-child(2) { border-bottom: 1px solid var(--color-line); }
    .ht-board { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 640px) {
    .ht-app { grid-template-columns: 1fr; }
    .ht-sidebar { display: none; }
    .ht-board { grid-template-columns: repeat(2, 1fr); }
    .ht-canvas-wrap { height: 420px; }
  }
</style>

<script>
(function () {
  const SEQUENCE = [
    { view: 'projects',  dur: 7800 },
    { view: 'tasks',     dur: 8200 },
    { view: 'resources', dur: 6600 },
  ];
  const URLS = {
    projects:  'projects/acme-website',
    tasks:     'tasks',
    resources: 'resources',
  };
  const ADD_TASK_TEXT = 'Implement Gus Gorman Payroll Hack';

  function prefersReducedMotion() {
    return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  }

  function initTour() {
    const canvas   = document.getElementById('ht-canvas');
    const sidebar  = document.getElementById('ht-sidebar');
    const urlpath  = document.getElementById('ht-urlpath');
    if (!canvas || !sidebar || !urlpath) return;

    // Snapshot the initial projects HTML before any modifications
    const projectsHTML = canvas.innerHTML;

    let seqIdx = 0;
    let cycleTimer = null;
    let viewTimers = [];

    function clearViewTimers() { viewTimers.forEach(clearTimeout); viewTimers = []; }

    // ── Projects modal ─────────────────────────────────────────────
    function buildModal() {
      const backdrop = document.createElement('div');
      backdrop.className = 'ht-backdrop';
      const modal = document.createElement('div');
      modal.className = 'ht-modal-in';
      modal.innerHTML = `
        <div style="display:flex;align-items:center;gap:9px;padding:14px 16px 10px">
          <span style="width:15px;height:15px;border-radius:999px;border:1.6px solid #3B82F6;flex-shrink:0"></span>
          <div class="cc-serif" style="font-size:15px;font-weight:700;color:var(--color-ink)">Inventory project assets</div>
          <span style="margin-left:auto;display:inline-flex;align-items:center;gap:5px;font-size:10.5px;color:var(--color-ink-3)">Close <span style="font-size:11px">✕</span></span>
        </div>
        <div style="display:grid;grid-template-columns:1fr 124px;gap:14px;padding:0 16px 16px">
          <div style="min-width:0">
            <div style="display:flex;align-items:center;gap:9px;margin-bottom:12px">
              <span style="width:20px;height:20px;border-radius:999px;background:#0A1F2E;color:#fff;font-size:8px;font-weight:700;display:inline-flex;align-items:center;justify-content:center">JW</span>
              <span style="font-size:10.5px;font-weight:600;color:var(--color-ink-2)">Jim Wykle</span>
              <span style="font-size:10px;color:var(--color-ink-3)">📅 Due: 7/15/2026</span>
            </div>
            <div style="font-size:10.5px;font-weight:700;color:var(--color-ink);margin-bottom:4px">Description</div>
            <div style="font-size:10.5px;color:var(--color-ink-2);line-height:1.5;margin-bottom:12px">The next step is to fix the inventory import so it includes categories.</div>
            <div style="font-size:10.5px;font-weight:700;color:var(--color-ink);margin-bottom:5px">Tags</div>
            <span style="display:inline-flex;align-items:center;gap:6px;font-size:9.5px;font-weight:600;padding:4px 9px;border-radius:5px;background:rgba(126,91,215,.12);color:#7E5BD7;margin-bottom:14px">Knowledge Base <span style="opacity:.6">✕</span></span>
            <div style="border:1px solid var(--color-line-2);border-radius:9px;padding:12px">
              <div style="font-size:11.5px;font-weight:700;color:var(--color-ink);margin-bottom:8px">Import Export Checklist</div>
              <div style="height:7px;border-radius:999px;background:var(--color-line-2);overflow:hidden"><div style="width:25%;height:100%;background:#6366F1"></div></div>
              <div style="font-size:9px;color:var(--color-ink-3);margin:4px 0 8px">1/4 completed</div>
              ${[
                ['Submit weekly status','07/29/2026',false],
                ['Team building exercise','07/25/2026',true],
                ['SWOT Analysis','',false],
                ['Make sure inventory export matches the import requirements','',false],
              ].map(([t,d,done]) => `
                <div style="display:flex;align-items:center;gap:8px;padding:4px 0">
                  <span style="width:13px;height:13px;border-radius:3px;flex-shrink:0;background:${done?'#22C55E':'#fff'};border:${done?'none':'1.4px solid var(--color-ink-4)'};display:inline-flex;align-items:center;justify-content:center">${done?'<svg width="8" height="8" viewBox="0 0 12 12"><path d="M2.5 6.5L5 9l4.5-5.5" stroke="#fff" stroke-width="2.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>':''}</span>
                  <span style="flex:1;font-size:10px;color:${done?'var(--color-ink-4)':'var(--color-ink)'};text-decoration:${done?'line-through':'none'}">${t}</span>
                  ${d?`<span class="num" style="font-size:8.5px;color:var(--color-ink-3);border:1px solid var(--color-line);border-radius:4px;padding:2px 6px">${d}</span>`:''}
                </div>`).join('')}
            </div>
          </div>
          <div style="display:flex;flex-direction:column;gap:5px">
            ${['Dates','Tags','Checklist','Images','Files','Reference'].map(b=>`<span style="font-size:9.5px;color:var(--color-ink-2);border:1px solid var(--color-line);border-radius:6px;padding:5px 8px">${b}</span>`).join('')}
            <div style="height:1px;background:var(--color-line-2);margin:3px 0"></div>
            ${['Move','Clone','Archive','Ticket'].map(b=>`<span style="font-size:9.5px;color:var(--color-ink-2);border:1px solid var(--color-line);border-radius:6px;padding:5px 8px">${b}</span>`).join('')}
            <div style="height:1px;background:var(--color-line-2);margin:3px 0"></div>
            <div style="font-size:8.5px;color:var(--color-ink-4)">Created Nov 13, 2025</div>
            <div style="font-size:8.5px;color:var(--color-ink-4)">Updated May 28, 2026</div>
          </div>
        </div>`;
      const frag = document.createDocumentFragment();
      frag.appendChild(backdrop);
      frag.appendChild(modal);
      return frag;
    }

    // ── Tasks animations ───────────────────────────────────────────
    function setupTasksAnimations() {
      if (prefersReducedMotion()) return;
      const inputSlot = document.getElementById('tasks-input-slot');
      const rowsEl = document.getElementById('tasks-rows');
      if (!inputSlot || !rowsEl) return;

      // 2.9s: show typing input (2s lead-in)
      viewTimers.push(setTimeout(() => {
        const wrap = document.createElement('div');
        wrap.className = 'ht-type-input';
        wrap.innerHTML = `
          <span style="width:16px;height:16px;border-radius:4px;background:var(--color-bg-2);border:1px solid var(--color-line);flex-shrink:0"></span>
          <div class="ht-type-field">
            <span id="ht-typed" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"></span>
            <span class="ht-caret"></span>
          </div>
          <span class="ht-add-btn-blue">Add</span>
          <span style="font-size:12px;color:var(--color-ink-4);padding:0 2px">✕</span>`;
        inputSlot.appendChild(wrap);

        // Type the task name
        let i = 0;
        const typedEl = document.getElementById('ht-typed');
        const typeIv = setInterval(() => {
          i++;
          if (typedEl) typedEl.textContent = ADD_TASK_TEXT.slice(0, i);
          if (i >= ADD_TASK_TEXT.length) clearInterval(typeIv);
        }, 58);
        viewTimers.push(typeIv);

        // After typing + 800ms: add the task row
        const addDelay = ADD_TASK_TEXT.length * 58 + 600;
        viewTimers.push(setTimeout(() => {
          if (inputSlot) inputSlot.innerHTML = '';
          const newRow = document.createElement('div');
          newRow.className = 'ht-task-row ht-task-new';
          newRow.innerHTML = `
            <span class="ht-hcheck"></span>
            <div style="min-width:0">
              <div class="ht-task-title">${ADD_TASK_TEXT}</div>
              <div class="ht-chips"><span class="ht-chip" style="background:#E6F6F6;color:#1F9999">Tomorrow</span></div>
            </div>`;
          rowsEl.insertBefore(newRow, rowsEl.firstChild);
          // update tabs counter
          const tabsEl = document.getElementById('tasks-tabs');
          if (tabsEl) {
            const todoTab = tabsEl.querySelector('.ht-tab-on');
            if (todoTab) todoTab.innerHTML = 'To Do <span class="num" style="color:var(--color-ink-4)">(6)</span>';
          }
        }, addDelay));
      }, 2900));

      // 6.8s: check row at index 3 (2s lead-in applied)
      viewTimers.push(setTimeout(() => {
        const rows = rowsEl.querySelectorAll('.ht-task-row');
        const target = rows[3];
        if (!target) return;
        target.classList.add('ht-task-done');
        const check = target.querySelector('.ht-hcheck');
        if (check) {
          check.classList.add('ht-done');
          check.innerHTML = '<svg width="8" height="8" viewBox="0 0 12 12"><path d="M2.5 6.5L5 9l4.5-5.5" stroke="#fff" stroke-width="2.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        }
        const stat = document.getElementById('tasks-incomplete-stat');
        if (stat) stat.textContent = '4';
      }, 6800));
    }

    // ── Resources animations ───────────────────────────────────────
    function setupResourcesAnimations() {
      if (prefersReducedMotion()) {
        // Just show landed state immediately
        const filesEl = document.getElementById('res-files');
        const dropWrap = document.getElementById('res-drop-wrap');
        if (dropWrap) dropWrap.remove();
        if (filesEl) {
          const card = document.createElement('div');
          card.className = 'ht-file-card';
          card.innerHTML = `<div class="ht-file-icon"><svg width="26" height="26" viewBox="0 0 24 24" fill="none"><path d="M6 2h8l4 4v16H6z" stroke="#3B82F6" stroke-width="1.4" stroke-linejoin="round"/><path d="M14 2v4h4" stroke="#3B82F6" stroke-width="1.4" stroke-linejoin="round"/><path d="M8.5 12h7M8.5 15h7M8.5 18h4" stroke="#3B82F6" stroke-width="1.2" stroke-linecap="round"/></svg></div><div style="font-size:10.5px;font-weight:600;color:var(--color-ink)">Brand-Guidelines.pdf</div><div style="font-size:9px;color:var(--color-ink-4);margin-top:3px;">Jun 1, 2026</div>`;
          filesEl.appendChild(card);
        }
        return;
      }

      // 2s lead-in: delay the drop animation, then show landed card at 3.25s
      const dropWrapEl = document.getElementById('res-drop-wrap');
      if (dropWrapEl) dropWrapEl.style.animation = 'heroDrop 1.25s cubic-bezier(.22,.7,.3,1) 2s both';

      viewTimers.push(setTimeout(() => {
        const dropWrap = document.getElementById('res-drop-wrap');
        const filesEl = document.getElementById('res-files');
        const countEl = document.getElementById('res-count');
        if (dropWrap) dropWrap.remove();
        if (filesEl) {
          const card = document.createElement('div');
          card.className = 'ht-file-card ht-file-added';
          card.innerHTML = `<div class="ht-file-icon"><svg width="26" height="26" viewBox="0 0 24 24" fill="none"><path d="M6 2h8l4 4v16H6z" stroke="#3B82F6" stroke-width="1.4" stroke-linejoin="round"/><path d="M14 2v4h4" stroke="#3B82F6" stroke-width="1.4" stroke-linejoin="round"/><path d="M8.5 12h7M8.5 15h7M8.5 18h4" stroke="#3B82F6" stroke-width="1.2" stroke-linecap="round"/></svg></div><div style="font-size:10.5px;font-weight:600;color:var(--color-ink)">Brand-Guidelines.pdf</div><div style="font-size:9px;color:var(--color-ink-4);margin-top:3px;">Jun 1, 2026</div>`;
          filesEl.appendChild(card);
        }
        if (countEl) countEl.textContent = '· 2 resources';
      }, 3250));
    }

    // ── View switcher ──────────────────────────────────────────────
    function activateView(view) {
      clearViewTimers();

      if (view === 'projects') {
        canvas.innerHTML = projectsHTML;
        if (!prefersReducedMotion()) {
          viewTimers.push(setTimeout(() => {
            const pad = canvas.querySelector('.ht-view-pad');
            if (pad && !pad.querySelector('.ht-backdrop')) {
              pad.appendChild(buildModal());
            }
          }, 4700));
        }
      } else {
        const tpl = document.getElementById('tpl-' + view);
        if (!tpl) return;
        canvas.innerHTML = '';
        canvas.appendChild(tpl.content.cloneNode(true));
        if (view === 'tasks') setupTasksAnimations();
        if (view === 'resources') setupResourcesAnimations();
      }

      sidebar.dataset.active = view;
      urlpath.textContent = URLS[view];

      // Trigger view entrance animation
      const viewEl = canvas.querySelector('.ht-view');
      if (viewEl) { viewEl.style.animation = 'none'; viewEl.offsetHeight; viewEl.style.animation = ''; }
    }

    function cycle() {
      seqIdx = (seqIdx + 1) % SEQUENCE.length;
      activateView(SEQUENCE[seqIdx].view);
      cycleTimer = setTimeout(cycle, SEQUENCE[seqIdx].dur);
    }

    // Start: show projects modal, then begin cycling
    if (!prefersReducedMotion()) {
      viewTimers.push(setTimeout(() => {
        const pad = canvas.querySelector('.ht-view-pad');
        if (pad && !pad.querySelector('.ht-backdrop')) {
          pad.appendChild(buildModal());
        }
      }, 4700));
    }
    cycleTimer = setTimeout(cycle, SEQUENCE[0].dur);
  }

  // Defer until browser is idle (after LCP)
  if ('requestIdleCallback' in window) {
    requestIdleCallback(initTour, { timeout: 3000 });
  } else {
    setTimeout(initTour, 200);
  }
})();
</script>
