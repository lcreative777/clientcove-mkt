---
const benefits = [
  {
    color: 'orange',
    title: 'Reclaim your time.',
    body: 'No more scattered emails, drives, and logins. Every client conversation, file, and invoice lives in one branded hub.',
    icon: 'clock',
    span: 4,
  },
  {
    color: 'teal',
    title: 'A premium client experience.',
    body: 'Your domain, your colors, your logo. Clients log in to your portal — they never see ClientCove.',
    icon: 'sparkle',
    span: 4,
  },
  {
    color: 'violet',
    title: 'A real company brain.',
    body: 'Turn your knowledge and processes into something searchable, structured, and smarter every day.',
    icon: 'brain',
    span: 4,
  },
  {
    color: 'navy',
    title: 'Future-proof with AI.',
    body: 'Connect Claude, custom agents, and your own automations. The platform extends with one prompt — not a year-long feature request.',
    icon: 'bolt',
    span: 6,
  },
  {
    color: 'green',
    title: 'Complete ownership.',
    body: 'Your data, your rules, your portal. Self-host on your VPS or let us run it. Either way, the database — and the source — are yours.',
    icon: 'shield',
    span: 6,
  },
];

const COLOR_MAP = {
  orange: { fg: 'var(--color-orange)',     bg: 'var(--color-orange-50)' },
  teal:   { fg: 'var(--color-teal-600)',   bg: 'var(--color-teal-50)' },
  violet: { fg: 'var(--color-violet)',     bg: 'rgba(126,91,215,.10)' },
  navy:   { fg: 'var(--color-navy-900)',   bg: 'rgba(10,31,46,.06)' },
  green:  { fg: 'var(--color-green)',      bg: 'rgba(24,165,122,.12)' },
} as const;
---
<section class="sect why-cc" id="why">
  <div class="container-wide">
    <div class="reveal why-head">
      <div class="eyebrow" style="margin-bottom:18px;">
        <span class="badge">WHY CLIENTCOVE</span> Five shifts you feel on day one
      </div>
      <h2 class="cc-h1">
        <em class="acc">Elevate</em> business.
      </h2>
    </div>

    <div class="why-grid">
      {benefits.map(b => {
        const c = COLOR_MAP[b.color as keyof typeof COLOR_MAP];
        return (
          <article class="card reveal why-card" style={`grid-column: span ${b.span};`}>
            <span class="why-icon" style={`background:${c.bg};color:${c.fg};`}>
              {b.icon === 'clock' && (
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M11 6.5v5l3 2"/></svg>
              )}
              {b.icon === 'sparkle' && (
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M11 3 12.6 8.4 18 10l-5.4 1.6L11 17l-1.6-5.4L4 10l5.4-1.6Z"/><path d="M17 4l.7 2L19 6.7l-1.3.7L17 9l-.7-1.6L15 6.7 16.3 6 17 4Z"/></svg>
              )}
              {b.icon === 'brain' && (
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3a3 3 0 0 0-3 3 3 3 0 0 0-2 5 3 3 0 0 0 2 5 3 3 0 0 0 3 3V3Z"/><path d="M13 3a3 3 0 0 1 3 3 3 3 0 0 1 2 5 3 3 0 0 1-2 5 3 3 0 0 1-3 3V3Z"/></svg>
              )}
              {b.icon === 'bolt' && (
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 13h6l-1 7 8-11h-6l1-7Z"/></svg>
              )}
              {b.icon === 'shield' && (
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M11 2 4 5v6c0 4 3 7 7 9 4-2 7-5 7-9V5l-7-3Z"/><path d="m8 11 2 2 4-4"/></svg>
              )}
            </span>
            <h3 class="cc-h3 why-title">{b.title}</h3>
            <p class="why-body">{b.body}</p>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .why-cc { background: #fff; }

  .why-head {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 56px;
  }
  .why-head .eyebrow { justify-content: center; }
  .why-head .cc-h1 { text-wrap: balance; }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 14px;
  }
  .why-card {
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: border-color .2s ease, transform .2s ease;
    height: 100%;
  }
  .why-card:hover { border-color: var(--color-ink-3); transform: translateY(-2px); }
  .why-icon {
    width: 44px; height: 44px;
    border-radius: 10px;
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .why-title {
    font-size: 19px; line-height: 1.25; font-weight: 700;
    color: var(--color-ink); margin: 0;
    text-wrap: balance;
  }
  .why-body {
    font-size: 14.5px; line-height: 1.6; color: var(--color-ink-2);
    margin: 0;
    text-wrap: pretty;
  }

  @media (max-width: 1000px) {
    .why-grid > .why-card { grid-column: span 6; }
  }
  @media (max-width: 640px) {
    .why-grid > .why-card { grid-column: span 12; }
  }
</style>
