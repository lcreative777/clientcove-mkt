---
import Icon from '~/components/ui/Icon.astro';
---
<section class="trust-section">
  <div class="container-wide trust-grid">
    <ul class="trust-points">
      <li><Icon name="bolt" /> <span>Extends with Claude Code — the source is yours</span></li>
      <li><Icon name="globe" /> <span>Fully white-label — branded as your own</span></li>
      <li><Icon name="shield" /> <span>Unlimited clients &amp; users — never per-seat</span></li>
    </ul>
    <div class="cloud-wrap">
      <div class="marquee">
        <span style="font-family:Georgia,serif;font-weight:700;">Acme Corp</span>
        <span style="font-family:'Inter Tight';font-weight:800;letter-spacing:-0.02em;">Cyberdyne</span>
        <span style="font-family:Georgia,serif;font-weight:400;font-style:italic;">LayerCake</span>
        <span style="font-family:'Inter Tight';font-weight:700;letter-spacing:-0.02em;">Metronet</span>
        <span style="font-family:Georgia,serif;font-weight:600;">SoCal Edison</span>
        <span style="font-family:'Inter Tight';font-weight:800;letter-spacing:-0.02em;">Verizon</span>
        <span style="font-family:Georgia,serif;font-weight:500;font-style:italic;">Wiklist</span>
        <span style="font-family:'Inter Tight';font-weight:700;letter-spacing:-0.02em;">Northwind</span>
        <span style="font-family:Georgia,serif;font-weight:700;">Apex Studio</span>
        <span style="font-family:'Inter Tight';font-weight:600;letter-spacing:-0.02em;">Trailhead</span>
        <!-- duplicate for marquee loop -->
        <span style="font-family:Georgia,serif;font-weight:700;">Acme Corp</span>
        <span style="font-family:'Inter Tight';font-weight:800;letter-spacing:-0.02em;">Cyberdyne</span>
        <span style="font-family:Georgia,serif;font-weight:400;font-style:italic;">LayerCake</span>
        <span style="font-family:'Inter Tight';font-weight:700;letter-spacing:-0.02em;">Metronet</span>
        <span style="font-family:Georgia,serif;font-weight:600;">SoCal Edison</span>
        <span style="font-family:'Inter Tight';font-weight:800;letter-spacing:-0.02em;">Verizon</span>
        <span style="font-family:Georgia,serif;font-weight:500;font-style:italic;">Wiklist</span>
        <span style="font-family:'Inter Tight';font-weight:700;letter-spacing:-0.02em;">Northwind</span>
        <span style="font-family:Georgia,serif;font-weight:700;">Apex Studio</span>
        <span style="font-family:'Inter Tight';font-weight:600;letter-spacing:-0.02em;">Trailhead</span>
      </div>
    </div>
  </div>
</section>

<style>
  .trust-section {
    padding: 56px 0;
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    background: #fff;
  }
  .trust-grid {
    display: grid; gap: 36px;
    grid-template-columns: 1fr 1.4fr;
    align-items: center;
  }
  .trust-points {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 10px;
    font-size: 13.5px; color: var(--color-ink-2);
  }
  .trust-points li { display: flex; align-items: center; gap: 10px; }
  .trust-points svg { color: var(--color-teal-600); }
  .cloud-wrap {
    overflow: hidden; position: relative;
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
            mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }
  .cloud-wrap span {
    font-size: 22px; color: var(--color-ink-3); white-space: nowrap;
  }
  @media (max-width: 980px) {
    .trust-grid { grid-template-columns: 1fr; gap: 22px; }
  }
</style>
