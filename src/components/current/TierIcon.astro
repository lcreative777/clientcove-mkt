---
interface Props {
  kind: 'mail' | 'wave' | 'spark';
  color?: string;
  size?: number;
}
const { kind, color = '#2BB3B3', size = 24 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  {kind === 'mail' && <><rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 8l9 6 9-6"/></>}
  {kind === 'wave' && <><path d="M2 12c2-3 4-3 6 0s4 3 6 0 4-3 6 0"/><path d="M2 17c2-3 4-3 6 0s4 3 6 0 4-3 6 0" opacity=".5"/><path d="M2 7c2-3 4-3 6 0s4 3 6 0 4-3 6 0" opacity=".5"/></>}
  {kind === 'spark' && <><path d="M12 2v4M12 18v4M2 12h4M18 12h4M5 5l3 3M16 16l3 3M5 19l3-3M16 8l3-3"/><circle cx="12" cy="12" r="3"/></>}
</svg>
