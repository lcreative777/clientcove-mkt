---
import Icon from './ui/Icon.astro';

interface Item { q: string; a: string; }
interface Props {
  items: Item[];
  eyebrow?: string;
  heading?: string;
  intro?: string;
}
const { items, eyebrow = 'FAQ', heading = 'Questions, fielded.', intro } = Astro.props;
---
<section class="sect faq-section" id="faq">
  <div class="container-wide faq-grid">
    <div class="reveal">
      <div class="eyebrow teal" style="margin-bottom:18px;">
        <span class="badge">{eyebrow}</span>
      </div>
      <h2 class="cc-h1">{heading}</h2>
      {intro && <p class="faq-intro">{intro}</p>}
      <p class="faq-intro">
        Can't find your answer? <a href="/contact" class="lnk">Email us <Icon name="arrow" /></a>
      </p>
    </div>
    <div class="faq-list reveal">
      {items.map((it, i) => (
        <details class="faq-item" open={i === 0}>
          <summary>
            <span class="cc-h3" style="font-size:19px;color:var(--color-ink);">{it.q}</span>
            <span class="faq-icon"><Icon name="plus" /></span>
          </summary>
          <div class="faq-body">
            <div>
              <p>{it.a}</p>
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-grid {
    display: grid; grid-template-columns: 1fr 2fr; gap: 80px;
    align-items: flex-start;
  }
  .faq-intro { font-size: 16px; line-height: 1.55; color: var(--color-ink-2); margin-top: 18px; }
  .faq-list { border-top: 1px solid var(--color-line); }
  .faq-item { border-bottom: 1px solid var(--color-line); }
  .faq-item summary {
    padding: 22px 0; display: flex;
    justify-content: space-between; align-items: center; gap: 20px;
  }
  .faq-icon {
    width: 28px; height: 28px; border-radius: 999px;
    background: var(--color-bg-2); color: var(--color-ink-2);
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .faq-body p {
    font-size: 15px; line-height: 1.65; color: var(--color-ink-2);
    padding: 0 60px 22px 0; margin: 0;
  }
  @media (max-width: 880px) {
    .faq-grid { grid-template-columns: 1fr; gap: 32px; }
    .faq-body p { padding-right: 0; }
  }
</style>
