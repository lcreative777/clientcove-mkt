---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'center' | 'left';
}
const { eyebrow, title, subtitle, align = 'center' } = Astro.props;
---
<section class="page-hero">
  <svg class="page-hero-mesh" viewBox="0 0 1600 600" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <defs>
      <radialGradient id="ph1" cx="20%" cy="20%" r="50%">
        <stop offset="0%" stop-color="#E76F2A" stop-opacity=".22" />
        <stop offset="100%" stop-color="#E76F2A" stop-opacity="0" />
      </radialGradient>
      <radialGradient id="ph2" cx="80%" cy="20%" r="50%">
        <stop offset="0%" stop-color="#2BB3B3" stop-opacity=".22" />
        <stop offset="100%" stop-color="#2BB3B3" stop-opacity="0" />
      </radialGradient>
      <linearGradient id="phfade" x1="0" x2="0" y1="0" y2="1">
        <stop offset="0%" stop-color="#fff" stop-opacity="0" />
        <stop offset="100%" stop-color="#fff" stop-opacity="1" />
      </linearGradient>
    </defs>
    <rect width="1600" height="600" fill="url(#ph1)" />
    <rect width="1600" height="600" fill="url(#ph2)" />
    <rect x="0" y="400" width="1600" height="200" fill="url(#phfade)" />
  </svg>
  <div class="grid-bg page-hero-grid" aria-hidden="true"></div>
  <div class="container" style={`position:relative;z-index:1;text-align:${align};`}>
    {eyebrow && (
      <div class="eyebrow" style="margin-bottom:18px;justify-content:center;">
        <span class="badge">{eyebrow}</span>
      </div>
    )}
    <h1 class="cc-h1 reveal" style="max-width:880px;margin:0 auto;"><Fragment set:html={title} /></h1>
    {subtitle && (
      <p class="page-hero-sub reveal" set:html={subtitle}></p>
    )}
    <div class="reveal"><slot /></div>
  </div>
</section>

<style>
  .page-hero { position: relative; padding: 100px 0 80px; overflow: hidden; }
  .page-hero-mesh { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; }
  .page-hero-grid {
    position: absolute; inset: 0; z-index: 0; opacity: .5;
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, black 30%, transparent 80%);
            mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, black 30%, transparent 80%);
  }
  .page-hero-sub {
    font-size: 19px; line-height: 1.55; color: var(--color-ink-2);
    max-width: 680px; margin: 22px auto 0; text-wrap: pretty;
  }
</style>
